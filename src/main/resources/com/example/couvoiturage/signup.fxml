<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.couvoiturage.controller.SignupController">
    <StackPane style="-fx-background-color: #f0f2f5;">
        <padding>
            <Insets bottom="50.0" left="20.0" right="20.0" top="50.0" />
        </padding>
        <VBox alignment="CENTER" spacing="30.0" maxWidth="600" styleClass="card">
            <padding>
                <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
            </padding>

            <VBox spacing="5" alignment="CENTER">
                <Label text="Créer un compte" styleClass="title-label" />
                <Label text="Rejoignez la communauté Fi Thnitek dès aujourd'hui." style="-fx-text-fill: #7f8c8d;" />
            </VBox>

            <GridPane hgap="20" vgap="20" alignment="CENTER">
                <columnConstraints>
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                </columnConstraints>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Nom *" />
                    <TextField fx:id="nomField" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Prénom" />
                    <TextField fx:id="prenomField" />
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="CIN *" />
                    <TextField fx:id="cinField" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Téléphone" />
                    <TextField fx:id="telephoneField" />
                </VBox>

                <VBox spacing="5" GridPane.columnSpan="2" GridPane.rowIndex="2">
                    <Label text="Email *" />
                    <TextField fx:id="emailField" />
                </VBox>

                <VBox spacing="5" GridPane.columnSpan="2" GridPane.rowIndex="3">
                    <Label text="Mot de passe *" />
                    <PasswordField fx:id="passwordField" />
                </VBox>

                <VBox spacing="5" GridPane.columnSpan="2" GridPane.rowIndex="4">
                    <Label text="Je suis un..." />
                    <ComboBox fx:id="roleComboBox" onAction="#handleRoleSelection" maxWidth="Infinity" promptText="Choisir un rôle" />
                </VBox>
            </GridPane>

            <!-- Section documents conducteur (masquée par défaut) -->
            <VBox fx:id="conducteurFields" spacing="15" managed="false" visible="false" style="-fx-border-color: #eee; -fx-border-width: 1 0 0 0; -fx-padding: 15 0 0 0;">
                <Label text="Documents requis" style="-fx-font-weight: bold;" />

                <!-- Carte Grise -->
                <VBox spacing="5">
                    <Label text="Carte Grise *" />
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="carteGrisFileLabel" text="Aucun fichier sélectionné"
                               style="-fx-text-fill: #7f8c8d; -fx-font-style: italic;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        <Button text="Parcourir..." onAction="#handleChooseCarteGris"
                                style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                    </HBox>
                </VBox>

                <!-- Permis de Conduire -->
                <VBox spacing="5">
                    <Label text="Permis de Conduire *" />
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="permisFileLabel" text="Aucun fichier sélectionné"
                               style="-fx-text-fill: #7f8c8d; -fx-font-style: italic;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                        <Button text="Parcourir..." onAction="#handleChoosePermis"
                                style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                    </HBox>
                </VBox>
            </VBox>

            <VBox spacing="10" alignment="CENTER">
                <Button text="S'INSCRIRE" onAction="#handleSignup" maxWidth="Infinity" />
                <Hyperlink text="Déjà inscrit ? Se connecter" onAction="#goToLogin" />
            </VBox>

            <Label fx:id="messageLabel" textFill="#e74c3c" wrapText="true" />
        </VBox>
    </StackPane>
</ScrollPane>
