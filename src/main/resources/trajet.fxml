<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.TrajetController"
      styleClass="page-container"
      spacing="16">
    <padding>
        <Insets top="24" left="24" right="24" bottom="24"/>
    </padding>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch"
                   promptText="Rechercher par ville, conducteur..."
                   styleClass="search-field"
                   prefWidth="320"/>
        <ComboBox fx:id="cbStatut" styleClass="combo-filter" prefWidth="150"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTotal" styleClass="badge-count"/>
        <Button text="Actualiser" styleClass="btn-secondary" onAction="#handleRefresh"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colId"          text="#"           prefWidth="45"/>
            <TableColumn fx:id="colDepart"       text="Depart"      prefWidth="110"/>
            <TableColumn fx:id="colDestination"  text="Destination" prefWidth="110"/>
            <TableColumn fx:id="colDate"         text="Date depart" prefWidth="140"/>
            <TableColumn fx:id="colPrix"         text="Prix"        prefWidth="90"/>
            <TableColumn fx:id="colPlaces"       text="Places"      prefWidth="80"/>
            <TableColumn fx:id="colConducteur"   text="Conducteur"  prefWidth="140"/>
            <TableColumn fx:id="colStatut"       text="Statut"      prefWidth="100"/>
            <TableColumn fx:id="colActions"      text="Actions"     prefWidth="200"/>
        </columns>
        <placeholder>
            <Label text="Aucun trajet trouve" styleClass="table-placeholder"/>
        </placeholder>
    </TableView>
</VBox>