<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.PassagerHomePageController"
            prefWidth="1100.0" prefHeight="700.0"
            style="-fx-background-color: #F5F6FA;">

    <top>
        <HBox prefHeight="62" alignment="CENTER_LEFT"
              style="-fx-background-image: url('/BACKGROUND.png');
           -fx-background-size: cover;
           -fx-background-position: center;
           -fx-border-color: #DDE2F0;
           -fx-border-width: 0 0 1 0;
           -fx-padding: 0 20 0 20;
           -fx-spacing: 10;">

            <!-- Logo -->
            <VBox alignment="CENTER_LEFT" spacing="0">
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="Fi"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #9B8FD4;" />
                    <Label text="Thnitek"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2BBF8A;" />
                </HBox>
                <Label text="SMART CARPOOLING"
                       style="-fx-font-size: 8px; -fx-text-fill: #6670A0;
                           -fx-letter-spacing: 2px;" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Infos utilisateur -->
            <HBox spacing="10" alignment="CENTER"
                  style="-fx-background-color: #3D3D8A;
                       -fx-background-radius: 20;
                       -fx-padding: 6 14;">
                <Label text="👤"
                       style="-fx-font-size: 14px;" />
                <VBox spacing="0">
                    <Label fx:id="nomUserLabel" text="Passager"
                           style="-fx-text-fill: white; -fx-font-size: 12px;
                               -fx-font-weight: bold;" />
                    <Label text="Passager"
                           style="-fx-text-fill: #8892B8; -fx-font-size: 10px;" />
                </VBox>
            </HBox>

            <!-- Bouton déconnexion -->
            <Button text="⏻  Déconnexion" onAction="#deconnecterAction"
                    prefHeight="36"
                    style="-fx-background-color: transparent;
                       -fx-text-fill: #FF6B6B;
                       -fx-font-size: 12px;
                       -fx-font-weight: bold;
                       -fx-border-color: #FF6B6B;
                       -fx-border-width: 1;
                       -fx-border-radius: 6;
                       -fx-background-radius: 6;
                       -fx-cursor: hand;
                       -fx-padding: 0 14;" />
        </HBox>
    </top>

    <center>
        <TabPane fx:id="passagerTabs"
                 tabClosingPolicy="UNAVAILABLE"
                 prefWidth="1100.0" prefHeight="638.0"
                 style="-fx-background-color: #F5F6FA;
                   -fx-tab-min-height: 42px;
                   -fx-tab-max-height: 42px;">

            <Tab fx:id="trajetTabButton" text="🛣   Trajets">
                <content>
                    <AnchorPane fx:id="trajetTab"
                                prefWidth="1100.0" prefHeight="596.0"
                                style="-fx-background-color: #F5F6FA;" />
                </content>
            </Tab>

            <Tab text="📅   Réservations">
                <content>
                    <AnchorPane fx:id="reservationTab"
                                prefWidth="1100.0" prefHeight="596.0"
                                style="-fx-background-color: #F5F6FA;" />
                </content>
            </Tab>

            <Tab text="💬   Forum">
                <content>
                    <AnchorPane fx:id="forumTab"
                                prefWidth="1100.0" prefHeight="596.0"
                                style="-fx-background-color: #F5F6FA;" />
                </content>
            </Tab>

            <Tab text="⚠   Réclamations">
                <content>
                    <AnchorPane fx:id="reclamationTab"
                                prefWidth="1100.0" prefHeight="596.0"
                                style="-fx-background-color: #F5F6FA;" />
                </content>
            </Tab>

            <Tab text="👤   Mon Profil">
                <content>
                    <AnchorPane fx:id="profileTab"
                                prefWidth="1100.0" prefHeight="596.0"
                                style="-fx-background-color: #F5F6FA;" />
                </content>
            </Tab>

        </TabPane>
    </center>

</BorderPane>