<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.PassagerHomeController"
            styleClass="root-pane"
            stylesheets="@../css/passager-theme.css">

    <!-- ═══════════════════════════ TOP NAV BAR ═══════════════════════════ -->
    <top>
        <HBox styleClass="top-navbar-passager" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🧳" styleClass="logo-icon"/>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="RideApp" styleClass="app-title"/>
                    <Label text="Espace Passager" styleClass="app-subtitle-passager"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Search bar rapide trajets -->
            <HBox styleClass="search-box" alignment="CENTER" spacing="6">
                <TextField fx:id="tfRechercheTrajet"
                           promptText="🔍  Rechercher un trajet..."
                           styleClass="search-field"
                           prefWidth="260"
                           onAction="#rechercherTrajet"/>
                <Button text="Chercher" styleClass="btn-search-go" onAction="#rechercherTrajet"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Notification + Profil -->
            <HBox alignment="CENTER_RIGHT" spacing="14">

                <!-- Notification Bell -->
                <StackPane>
                    <Button fx:id="btnNotifications"
                            text="🔔"
                            styleClass="notif-btn-passager"
                            onAction="#toggleNotificationPanel"/>
                    <Label fx:id="notifBadge" text="1" styleClass="notif-badge-passager"
                           StackPane.alignment="TOP_RIGHT"
                           visible="false"/>
                </StackPane>

                <!-- Profil Passager -->
                <HBox alignment="CENTER" spacing="8" styleClass="profil-box-passager">
                    <Circle radius="18" styleClass="avatar-passager"/>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label fx:id="lblPassagerNom" text="Passager" styleClass="nom-passager"/>
                        <HBox spacing="3" alignment="CENTER_LEFT">
                            <Label text="⭐" styleClass="star-mini"/>
                            <Label fx:id="lblNotePassager" text="5.0" styleClass="note-passager"/>
                        </HBox>
                    </VBox>
                    <Button text="⏻" styleClass="logout-btn" onAction="#logout">
                        <tooltip><Tooltip text="Déconnexion"/></tooltip>
                    </Button>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <!-- ═══════════════════════════ MAIN CONTENT ═══════════════════════════ -->
    <center>
        <StackPane>

            <!-- Main Notebook -->
            <VBox spacing="0">

                <!-- Bandeau de bienvenue + résumé -->
                <HBox styleClass="welcome-banner-passager" alignment="CENTER_LEFT" spacing="20">
                    <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>

                    <VBox spacing="2">
                        <Label fx:id="lblBienvenue" text="Bonjour, Passager 👋"
                               styleClass="welcome-greeting"/>
                        <Label fx:id="lblProchainTrajet" text="Votre prochain trajet: —"
                               styleClass="prochain-trajet-info"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <!-- Stats rapides -->
                    <HBox spacing="20" alignment="CENTER_RIGHT">
                        <VBox alignment="CENTER" styleClass="quick-stat">
                            <Label fx:id="kpiTrajetsEffectues" text="—" styleClass="qs-value"/>
                            <Label text="Trajets" styleClass="qs-label"/>
                        </VBox>
                        <VBox alignment="CENTER" styleClass="quick-stat">
                            <Label fx:id="kpiDepensesMois" text="—" styleClass="qs-value-blue"/>
                            <Label text="Ce mois" styleClass="qs-label"/>
                        </VBox>
                        <VBox alignment="CENTER" styleClass="quick-stat">
                            <Label fx:id="kpiReservationsActives" text="—" styleClass="qs-value-green"/>
                            <Label text="Réservations" styleClass="qs-label"/>
                        </VBox>
                    </HBox>
                </HBox>

                <!-- TabPane principal -->
                <TabPane fx:id="mainTabPane"
                         styleClass="main-notebook-passager"
                         tabClosingPolicy="UNAVAILABLE"
                         VBox.vgrow="ALWAYS">

                    <!-- ── TAB 1 : Trajets & Réservations (première) ── -->
                    <Tab fx:id="tabTrajets" text="🗺️  Trajets & Réservations" closable="false">
                        <content>
                            <!--
                                Ce panneau inclut un bouton "Voir les Véhicules disponibles"
                                géré par PassagerHomeController#ouvrirVehiculesDialog()
                                qui ouvre GestionVehicules.fxml en dialog/popup
                            -->
                            <VBox spacing="0">
                                <!-- Toolbar spéciale trajets avec bouton Véhicules -->
                                <HBox styleClass="trajet-toolbar" alignment="CENTER_LEFT" spacing="12">
                                    <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                                    <Label text="Rechercher et réserver un trajet" styleClass="trajet-toolbar-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <!-- BOUTON VEHICULES : ouvre le panneau véhicules disponibles -->
                                    <Button fx:id="btnVoirVehicules"
                                            text="🚙  Véhicules disponibles"
                                            styleClass="btn-vehicules-passager"
                                            onAction="#ouvrirVehiculesDialog"/>
                                </HBox>

                                <!-- Contenu trajets principal -->
                                <fx:include fx:id="trajetsController"
                                            source="../views/passager/TrajetsReservations.fxml"
                                            VBox.vgrow="ALWAYS"/>
                            </VBox>
                        </content>
                    </Tab>

                    <!-- ── TAB 2 : Revenus & Transactions passager ── -->
                    <Tab text="💳  Mes Paiements" closable="false">
                        <content>
                            <fx:include source="../views/passager/RevenusTransactions.fxml"/>
                        </content>
                    </Tab>

                    <!-- ── TAB 3 : Forum ── -->
                    <Tab text="💬  Forum" closable="false">
                        <content>
                            <fx:include source="ListeForum.fxml"/>
                        </content>
                    </Tab>

                    <!-- ── TAB 4 : Réclamations ── -->
                    <Tab text="📋  Réclamations" closable="false">
                        <content>
                            <fx:include source="../views/passager/Reclamations.fxml"/>
                        </content>
                    </Tab>

                    <!-- ── TAB 5 : Mon Profil ── -->
                    <Tab text="👤  Mon Profil" closable="false">
                        <content>
                            <fx:include source="../views/passager/MonProfil.fxml"/>
                        </content>
                    </Tab>

                </TabPane>
            </VBox>

            <!-- ═══ PANNEAU NOTIFICATIONS (slide-in overlay) ═══ -->
            <VBox fx:id="notificationPanel"
                  styleClass="notif-panel-passager"
                  maxWidth="340"
                  StackPane.alignment="TOP_RIGHT"
                  visible="false"
                  managed="false">

                <HBox styleClass="notif-panel-header-passager" alignment="CENTER_LEFT">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label text="🔔  Notifications" styleClass="notif-panel-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" styleClass="notif-close-btn" onAction="#closeNotificationPanel"/>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="notif-scroll" VBox.vgrow="ALWAYS">
                    <VBox fx:id="notifListContainer" spacing="0" styleClass="notif-list"/>
                </ScrollPane>

                <HBox styleClass="notif-panel-footer" alignment="CENTER">
                    <padding><Insets top="10" right="0" bottom="10" left="0"/></padding>
                    <Button text="Tout marquer comme lu"
                            styleClass="btn-mark-all-read-passager"
                            onAction="#markAllRead"/>
                </HBox>
            </VBox>

            <!-- ═══ POPUP NOTIFICATION AU DÉMARRAGE ═══ -->
            <!--
                Toast/popup de notification au lancement de l'appli :
                géré programmatiquement depuis PassagerHomeController#initialize()
                via showStartupNotifications() — pas dans le FXML pour garder la flexibilité
                d'animation (FadeTransition + TranslateTransition)
            -->

        </StackPane>
    </center>

    <!-- ═══════════════════════════ STATUS BAR ═══════════════════════════ -->
    <bottom>
        <HBox styleClass="status-bar-passager" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="5" right="16" bottom="5" left="16"/></padding>
            <Circle radius="5" styleClass="status-dot-online"/>
            <Label fx:id="lblStatusPassager" text="Connecté" styleClass="status-text-passager"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblDateTime" text="" styleClass="status-datetime-passager"/>
        </HBox>
    </bottom>

</BorderPane>
