<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.PassagerHomePageController"
            prefWidth="1100.0" prefHeight="700.0"
            style="-fx-background-color: #F5F6FA;">

    <!-- TOP BAR -->
    <top>
        <HBox prefHeight="62" alignment="CENTER_LEFT"
              style="-fx-background-color: #2D2D6B">
            <VBox alignment="CENTER_LEFT" spacing="1">
                <HBox spacing="5" alignment="CENTER_LEFT">
                    <Label text="Fi"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #9B8FD4;" />
                    <Label text="Thnitek"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2BBF8A;" />
                </HBox>
                <Label text="SMART CARPOOLING"
                       style="-fx-font-size: 8px; -fx-text-fill: rgba(255,255,255,0.6);" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <VBox alignment="CENTER_RIGHT" spacing="1">
                <Label fx:id="nomUserLabel" text="Nom Prénom"
                       style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                <Label text="Passager"
                       style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 11px;" />
            </VBox>
            <Button text="⏻  Déconnexion" onAction="#deconnecterAction"
                    prefHeight="34"
                    style="-fx-background-color: transparent;
                       -fx-text-fill: #FF6B6B;
                       -fx-font-size: 12px;
                       -fx-font-weight: bold;
                       -fx-border-color: #FF6B6B;
                       -fx-border-width: 1;
                       -fx-border-radius: 6;
                       -fx-background-radius: 6;
                       -fx-cursor: hand;
                       -fx-padding: 0 14;" />
        </HBox>
    </top>

    <!-- SIDEBAR GAUCHE + CONTENU -->
    <center>
        <HBox>

            <!-- SIDEBAR -->
            <VBox prefWidth="200" spacing="4"
                  style="-fx-background-color: #2D2D6B;
                       -fx-padding: 16 0 16 0;">

                <Label text="NAVIGATION"
                       style="-fx-text-fill: #6670A0;
                           -fx-font-size: 10px;
                           -fx-font-weight: bold;
                           -fx-padding: 8 16 8 16;" />

                <Button fx:id="btnTrajets" text="🛣   Trajets"
                        maxWidth="Infinity" prefHeight="42"
                        onAction="#showTrajets"
                        style="-fx-background-color: #3D3D8A;
                           -fx-text-fill: white;
                           -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT;
                           -fx-padding: 0 0 0 20;
                           -fx-background-radius: 0;
                           -fx-cursor: hand;" />

                <Button fx:id="btnReservations" text="📅   Réservations"
                        maxWidth="Infinity" prefHeight="42"
                        onAction="#showReservations"
                        style="-fx-background-color: transparent;
                           -fx-text-fill: #B0B8D8;
                           -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT;
                           -fx-padding: 0 0 0 20;
                           -fx-background-radius: 0;
                           -fx-cursor: hand;" />

                <Button fx:id="btnForum" text="💬   Forum"
                        maxWidth="Infinity" prefHeight="42"
                        onAction="#showForum"
                        style="-fx-background-color: transparent;
                           -fx-text-fill: #B0B8D8;
                           -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT;
                           -fx-padding: 0 0 0 20;
                           -fx-background-radius: 0;
                           -fx-cursor: hand;" />

                <Button fx:id="btnReclamations" text="⚠   Réclamations"
                        maxWidth="Infinity" prefHeight="42"
                        onAction="#showReclamations"
                        style="-fx-background-color: transparent;
                           -fx-text-fill: #B0B8D8;
                           -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT;
                           -fx-padding: 0 0 0 20;
                           -fx-background-radius: 0;
                           -fx-cursor: hand;" />

                <Button fx:id="btnProfil" text="👤   Mon Profil"
                        maxWidth="Infinity" prefHeight="42"
                        onAction="#showProfil"
                        style="-fx-background-color: transparent;
                           -fx-text-fill: #B0B8D8;
                           -fx-font-size: 13px;
                           -fx-alignment: CENTER_LEFT;
                           -fx-padding: 0 0 0 20;
                           -fx-background-radius: 0;
                           -fx-cursor: hand;" />

                <Region VBox.vgrow="ALWAYS" />

                <!-- Version -->
                <Label text="Fi Thnitek v1.0"
                       style="-fx-text-fill: #4A4A8A;
                           -fx-font-size: 10px;
                           -fx-padding: 0 0 0 16;" />
            </VBox>

            <!-- CONTENU PRINCIPAL -->
            <AnchorPane fx:id="mainContainer"
                        HBox.hgrow="ALWAYS"
                        style="-fx-background-color: #F5F6FA;" />

        </HBox>
    </center>

</BorderPane>