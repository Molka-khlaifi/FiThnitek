<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.PassagerHomePageController"
            prefWidth="1280"
            prefHeight="800"
            style="-fx-background-color: #eef0f6;">

    <left>
        <VBox prefWidth="227" style="-fx-background-color: #302f73;">
            <padding>
                <Insets top="20" right="14" bottom="24" left="16"/>
            </padding>
            <Region VBox.vgrow="ALWAYS"/>
            <Label fx:id="lblStatusPassager" text="Fi Thnitek v1.0" style="-fx-text-fill: rgba(255,255,255,0.18); -fx-font-size: 11px;"/>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" minHeight="110" prefHeight="110"
              style="-fx-background-color: #302f73; -fx-padding: 0 18 0 16;">
            <VBox prefWidth="250" alignment="CENTER_LEFT" spacing="4">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="Fi" style="-fx-text-fill: #b9b7f4; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label text="Thnitek" style="-fx-text-fill: #21c891; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label text="PASSAGER"
                           style="-fx-background-color: #c6c1ff; -fx-text-fill: #24235f; -fx-font-weight: bold; -fx-background-radius: 16; -fx-padding: 5 10; -fx-font-size: 12px;"/>
                </HBox>
                <Label text="SMART CARPOOLING" style="-fx-text-fill: #b7b6db; -fx-font-size: 9px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="4">
                <Label fx:id="lblPassagerNom" text="Utilisateur Passager"
                       style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Label text="Passager" style="-fx-text-fill: #21c891; -fx-font-size: 12px;"/>
            </VBox>
            <Button text="Deconnexion" onAction="#logout"
                    style="-fx-background-color: transparent; -fx-border-color: #ff5964; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #ff5964; -fx-font-weight: bold; -fx-padding: 10 18; -fx-cursor: hand; -fx-translate-x: 24;"/>
        </HBox>
    </top>

    <center>
        <StackPane>
            <TabPane fx:id="mainTabPane"
                     tabClosingPolicy="UNAVAILABLE"
                     style="-fx-background-color: #eef0f6; -fx-tab-min-height: 50; -fx-tab-max-height: 50;">

                <Tab fx:id="tabTrajets" text="PROFIL" closable="false">
                    <content>
                        <fx:include source="/com/example/couvoiturage/user_home.fxml"/>
                    </content>
                </Tab>

                <Tab text="TRAJETS ET RESERVATIONS" closable="false">
                    <content>
                        <fx:include source="/dashboardTrajet.fxml"/>
                    </content>
                </Tab>

                <Tab text="FORUM" closable="false">
                    <content>
                        <fx:include source="/ListeForum.fxml"/>
                    </content>
                </Tab>

                <Tab text="RECLAMATIONS" closable="false">
                    <content>
                        <fx:include source="/views/ListeReclamationUser.fxml"/>
                    </content>
                </Tab>

                <Tab id="REVENU" text="PAIEMENTS" closable="false">
                    <content>
                        <fx:include source="/mainMenu.fxml"/>
                    </content>
                </Tab>
            </TabPane>

            <VBox fx:id="notificationPanel" maxWidth="340" StackPane.alignment="TOP_RIGHT" visible="false" managed="false">
                <VBox fx:id="notifListContainer"/>
            </VBox>
        </StackPane>
    </center>

    <bottom>
        <VBox visible="false" managed="false">
            <Label fx:id="lblNotePassager" text="5.0"/>
            <Label fx:id="lblBienvenue" text="Bonjour, Passager"/>
            <Label fx:id="lblProchainTrajet" text="Votre prochain trajet: -"/>
            <Label fx:id="kpiTrajetsEffectues" text="-"/>
            <Label fx:id="kpiDepensesMois" text="-"/>
            <Label fx:id="kpiReservationsActives" text="-"/>
            <TextField fx:id="tfRechercheTrajet" onAction="#rechercherTrajet"/>
            <Button fx:id="btnNotifications" text="Notifications" onAction="#toggleNotificationPanel"/>
            <Label fx:id="notifBadge" text="0"/>
            <Label fx:id="lblDateTime" text=""/>
        </VBox>
    </bottom>
</BorderPane>
