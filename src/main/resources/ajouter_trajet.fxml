<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AjouterTrajetController"
            fitToWidth="true"
            styleClass="scroll-pane">

    <VBox styleClass="page-container" spacing="24" maxWidth="720">
        <padding>
            <Insets top="32" left="40" right="40" bottom="32"/>
        </padding>

        <Label text="Nouveau trajet" styleClass="section-title"/>

        <!-- Card -->
        <VBox styleClass="card" spacing="20">
            <padding>
                <Insets top="24" left="24" right="24" bottom="24"/>
            </padding>

            <Label text="Informations du trajet" styleClass="card-section-label"/>

            <GridPane hgap="16" vgap="14">
                <columnConstraints>
                    <ColumnConstraints prefWidth="160" minWidth="140"/>
                    <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                </columnConstraints>

                <Label text="Ville de depart :"   GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
                <TextField fx:id="txtDepart"       GridPane.rowIndex="0" GridPane.columnIndex="1"
                           promptText="Ex: Tunis" styleClass="form-field"/>

                <Label text="Destination :"        GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
                <TextField fx:id="txtDestination"  GridPane.rowIndex="1" GridPane.columnIndex="1"
                           promptText="Ex: Sousse" styleClass="form-field"/>

                <Label text="Date de depart :"     GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
                <TextField fx:id="txtDateDepart"   GridPane.rowIndex="2" GridPane.columnIndex="1"
                           promptText="dd/MM/yyyy HH:mm" styleClass="form-field"/>

                <Label text="Date d arrivee :"     GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
                <TextField fx:id="txtDateArrivee"  GridPane.rowIndex="3" GridPane.columnIndex="1"
                           promptText="dd/MM/yyyy HH:mm" styleClass="form-field"/>

                <Label text="Prix (DT) :"          GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label"/>
                <TextField fx:id="txtPrix"         GridPane.rowIndex="4" GridPane.columnIndex="1"
                           promptText="Ex: 25.00" styleClass="form-field"/>

                <Label text="Nombre de places :"   GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="form-label"/>
                <TextField fx:id="txtPlaces"       GridPane.rowIndex="5" GridPane.columnIndex="1"
                           promptText="Ex: 4" styleClass="form-field"/>
            </GridPane>

            <Separator/>
            <Label text="Informations du conducteur" styleClass="card-section-label"/>

            <GridPane hgap="16" vgap="14">
                <columnConstraints>
                    <ColumnConstraints prefWidth="160" minWidth="140"/>
                    <ColumnConstraints hgrow="ALWAYS" fillWidth="true"/>
                </columnConstraints>

                <Label text="Nom conducteur :"     GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
                <TextField fx:id="txtConducteurNom" GridPane.rowIndex="0" GridPane.columnIndex="1"
                           promptText="Ex: Ahmed Ben Ali" styleClass="form-field"/>

                <Label text="Telephone :"          GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
                <TextField fx:id="txtConducteurTel" GridPane.rowIndex="1" GridPane.columnIndex="1"
                           promptText="Ex: 12345678" styleClass="form-field"/>

                <Label text="Matricule :"          GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
                <TextField fx:id="txtMatricule"    GridPane.rowIndex="2" GridPane.columnIndex="1"
                           promptText="Ex: 123 TUN 456" styleClass="form-field"/>

                <Label text="Description :"        GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
                <TextArea  fx:id="txtDescription"  GridPane.rowIndex="3" GridPane.columnIndex="1"
                           promptText="Informations complementaires..."
                           prefRowCount="3" wrapText="true" styleClass="form-field"/>
            </GridPane>

            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="Effacer"        styleClass="btn-secondary" onAction="#handleClear"/>
                <Button text="Creer le trajet" styleClass="btn-primary"  onAction="#handleAjouter"/>
            </HBox>

            <Label fx:id="lblMessage" styleClass="form-message" wrapText="true"/>
        </VBox>
    </VBox>
</ScrollPane>