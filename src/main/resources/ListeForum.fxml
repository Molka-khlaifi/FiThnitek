<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="580.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ListeForumController"
            style="-fx-background-color: #f9f9f9;">

    <!-- Header -->
    <Label layoutX="30.0" layoutY="25.0"
           text="Forum Covoiturage"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label fx:id="statsLabel"
           layoutX="540.0" layoutY="30.0"
           text="0 posts"
           style="-fx-text-fill: #888; -fx-font-size: 12px;"/>

    <Label layoutX="30.0" layoutY="62.0"
           text="────────────────────────────────────────────────────────"
           style="-fx-text-fill: #ddd;"/>

    <!-- Recherche -->
    <TextField fx:id="searchTextField"
               layoutX="30.0" layoutY="80.0"
               prefWidth="380.0" prefHeight="36.0"
               promptText="Rechercher un post par titre ou contenu..."
               style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #ddd; -fx-border-width: 1; -fx-background-color: white; -fx-padding: 0 10;"/>

    <Button layoutX="420.0" layoutY="80.0"
            text="Rechercher"
            onAction="#rechercherAction"
            prefWidth="110.0" prefHeight="36.0"
            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"/>

    <!-- Filtre categorie -->
    <ComboBox fx:id="categorieFilterComboBox"
              layoutX="544.0" layoutY="80.0"
              prefWidth="130.0" prefHeight="36.0"
              onAction="#filtrerCategorieAction"
              style="-fx-background-radius: 6;"/>

    <!-- Tri -->
    <Label layoutX="30.0" layoutY="130.0"
           text="Trier par :"
           style="-fx-text-fill: #888; -fx-font-size: 12px;"/>

    <Button layoutX="95.0" layoutY="126.0"
            text="Plus récents"
            onAction="#trierParDateAction"
            prefWidth="105.0" prefHeight="26.0"
            style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-width: 1; -fx-background-radius: 5; -fx-font-size: 11px; -fx-cursor: hand;"/>

    <Button layoutX="210.0" layoutY="126.0"
            text="Plus vus"
            onAction="#trierParVuesAction"
            prefWidth="90.0" prefHeight="26.0"
            style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-width: 1; -fx-background-radius: 5; -fx-font-size: 11px; -fx-cursor: hand;"/>

    <Button layoutX="310.0" layoutY="126.0"
            text="Plus commentés"
            onAction="#trierParCommentairesAction"
            prefWidth="125.0" prefHeight="26.0"
            style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-width: 1; -fx-background-radius: 5; -fx-font-size: 11px; -fx-cursor: hand;"/>

    <!-- ListView principale -->
    <ListView fx:id="publicationListView"
              layoutX="30.0" layoutY="165.0"
              prefWidth="640.0" prefHeight="240.0"
              style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1;"/>

    <!-- Zone actions -->
    <Label layoutX="30.0" layoutY="418.0"
           text="────────────────────────────────────────────────────────"
           style="-fx-text-fill: #ddd;"/>

    <Label layoutX="30.0" layoutY="435.0"
           text="ID du post sélectionné :"
           style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-font-size: 12px;"/>

    <TextField fx:id="idTextField"
               layoutX="200.0" layoutY="431.0"
               prefWidth="80.0" prefHeight="30.0"
               promptText="ex: 1"
               style="-fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-width: 1; -fx-background-color: white; -fx-padding: 0 8;"/>

    <!-- Boutons actions -->
    <Button layoutX="30.0" layoutY="478.0"
            text="+ Ajouter"
            onAction="#ajouterAction"
            prefWidth="110.0" prefHeight="36.0"
            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;"/>

    <Button layoutX="155.0" layoutY="478.0"
            text="Commentaires"
            onAction="#voirCommentairesAction"
            prefWidth="130.0" prefHeight="36.0"
            style="-fx-background-color: #1abc9c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;"/>

    <Button layoutX="300.0" layoutY="478.0"
            text="Mes Posts"
            onAction="#mesPostsAction"
            prefWidth="110.0" prefHeight="36.0"
            style="-fx-background-color: #0F6E56; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;"/>

    <!-- Message statut -->
    <Label fx:id="messageLabel"
           layoutX="30.0" layoutY="530.0"
           text=""
           style="-fx-text-fill: #27ae60; -fx-font-size: 12px;"/>

</AnchorPane>