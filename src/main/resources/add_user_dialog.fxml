<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" prefWidth="500">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Ajouter un nouvel utilisateur" styleClass="title-label" style="-fx-font-size: 18px;" />

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>

        <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label text="Nom *" />
            <TextField fx:id="addNomField" />
        </VBox>
        <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label text="Prénom *" />
            <TextField fx:id="addPrenomField" />
        </VBox>

        <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <Label text="CIN *" />
            <TextField fx:id="addCinField" />
        </VBox>
        <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <Label text="Téléphone" />
            <TextField fx:id="addPhoneField" />
        </VBox>

        <VBox spacing="5" GridPane.columnSpan="2" GridPane.rowIndex="2">
            <Label text="Email *" />
            <TextField fx:id="addEmailField" />
        </VBox>

        <VBox spacing="5" GridPane.columnSpan="2" GridPane.rowIndex="3">
            <Label text="Mot de passe *" />
            <PasswordField fx:id="addPasswordField" />
        </VBox>

        <VBox spacing="5" GridPane.columnSpan="2" GridPane.rowIndex="4">
            <Label text="Rôle *" />
            <ComboBox fx:id="addRoleComboBox" onAction="#handleAddRoleSelection" maxWidth="Infinity" />
        </VBox>
    </GridPane>

    <VBox fx:id="addConducteurFields" spacing="10" managed="false" visible="false" style="-fx-border-color: #eee; -fx-border-width: 1 0 0 0; -fx-padding: 10 0 0 0;">
        <Label text="Informations du véhicule" style="-fx-font-weight: bold;" />
        <GridPane hgap="10" vgap="10">
            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Marque" />
                <TextField fx:id="addMarqueField" />
            </VBox>
            <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Modèle" />
                <TextField fx:id="addModeleField" />
            </VBox>
            <VBox spacing="5" GridPane.columnSpan="2" GridPane.rowIndex="1">
                <Label text="Immatriculation" />
                <TextField fx:id="addImmatriculationField" />
            </VBox>
        </GridPane>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#handleCancelAdd" style="-fx-background-color: #95a5a6;" />
        <Button text="Créer l'utilisateur" onAction="#handleConfirmAdd" />
    </HBox>

    <Label fx:id="addMessageLabel" textFill="#e74c3c" wrapText="true" />
</VBox>
