<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<AnchorPane prefHeight="580.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.PostDetailsController"
            style="-fx-background-color: #f9f9f9;">

    <!-- Header -->
    <Label layoutX="30" layoutY="25"
           text="Détails du Post"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <!-- Carte centrale -->
    <VBox layoutX="30" layoutY="70" prefWidth="640" spacing="15"
          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #ddd;">

        <!-- Titre -->
        <Label fx:id="titreLabel"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <!-- Image -->
        <ImageView fx:id="imageView"
                   fitWidth="600"
                   fitHeight="200"
                   preserveRatio="true"
                   style="-fx-background-radius: 8;"/>

        <!-- Contenu -->
        <Label text="Contenu :" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
        <Label fx:id="contenuLabel" wrapText="true"
               style="-fx-text-fill: #333;"/>

        <!-- Infos -->
        <HBox spacing="20">
            <Label fx:id="categorieLabel" style="-fx-text-fill: #888;"/>
            <Label fx:id="dateLabel" style="-fx-text-fill: #888;"/>
            <Label fx:id="vuesLabel" style="-fx-text-fill: #888;"/>
        </HBox>

    </VBox>

    <!-- Bouton retour -->
    <Button layoutX="30" layoutY="520"
            text="← Retour"
            onAction="#retourAction"
            prefWidth="120" prefHeight="36"
            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 7; -fx-cursor: hand;"/>

</AnchorPane>