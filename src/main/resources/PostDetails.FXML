<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<BorderPane
        prefHeight="600.0" prefWidth="700.0"
        style="-fx-background-color: #F5F6FA;"
        xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="controllers.PostDetailsController">

    <top>
        <HBox prefHeight="56" alignment="CENTER_LEFT"
              style="-fx-background-image: url('/BACKGROUND.png');
           -fx-background-size: cover;
           -fx-background-position: center;
           -fx-border-color: #DDE2F0;
           -fx-border-width: 0 0 1 0;
           -fx-padding: 0 20 0 20;
           -fx-spacing: 10;">
            <Button onAction="#retourAction" prefHeight="30" prefWidth="90"
                    style="-fx-background-color: #3D3D8A; -fx-text-fill: #C0C8F0;
                       -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 12px;
                       -fx-border-color: #5B5BAA; -fx-border-width: 1; -fx-border-radius: 6;"
                    text="← Retour" />
            <Label text="Fi" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #9B8FD4;" />
            <Label text="Thnitek" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2BBF8A;" />
            <Label text="— Détails du Post" style="-fx-font-size: 14px; -fx-text-fill: #B0B8D8;" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true"
                    style="-fx-background-color: transparent; -fx-border-width: 0;">
            <content>
                <VBox spacing="14" style="-fx-padding: 16 24 16 24;">

                    <VBox spacing="14"
                          style="-fx-background-color: white; -fx-padding: 20;
                               -fx-background-radius: 10; -fx-border-radius: 10;
                               -fx-border-color: #DDE2F0; -fx-border-width: 1;">

                        <Label fx:id="titreLabel"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2D2D6B;"
                               wrapText="true" />

                        <HBox spacing="10">
                            <Label fx:id="categorieLabel"
                                   style="-fx-text-fill: white; -fx-background-color: #2BBF8A;
                                       -fx-background-radius: 5; -fx-padding: 3 10;
                                       -fx-font-size: 11px; -fx-font-weight: bold;" />
                            <Label fx:id="statutLabel"
                                   style="-fx-text-fill: white; -fx-background-color: #9B8FD4;
                                       -fx-background-radius: 5; -fx-padding: 3 10;
                                       -fx-font-size: 11px; -fx-font-weight: bold;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="dateLabel"
                                   style="-fx-text-fill: #888; -fx-font-size: 12px;" />
                            <Label fx:id="vuesLabel"
                                   style="-fx-text-fill: #888; -fx-font-size: 12px;" />
                        </HBox>

                        <ImageView fx:id="imageView" fitHeight="180"
                                   preserveRatio="true" />

                        <Label text="Contenu"
                               style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 13px;" />
                        <Label fx:id="contenuLabel"
                               style="-fx-text-fill: #444; -fx-font-size: 13px; -fx-line-spacing: 3;"
                               wrapText="true" />
                    </VBox>

                    <HBox spacing="12">
                        <Button onAction="#voirCommentairesAction" prefHeight="36"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color: #2BBF8A; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 7;
                                   -fx-font-size: 12px; -fx-cursor: hand;"
                                text="💬  Commentaires" />
                        <Button onAction="#retourAction" prefHeight="36"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color: white; -fx-border-color: #9B8FD4;
                                   -fx-border-width: 1; -fx-text-fill: #9B8FD4;
                                   -fx-background-radius: 7; -fx-font-size: 12px; -fx-cursor: hand;"
                                text="← Retour" />
                    </HBox>

                    <Label fx:id="messageLabel" wrapText="true"
                           style="-fx-text-fill: #2BBF8A; -fx-font-size: 12px; -fx-font-style: italic;" text="" />
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>