<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ConducteurHomeController"
            styleClass="root-pane"
            stylesheets="@../css/conducteur-theme.css">

    <!-- ═══════════════════════════ TOP NAV BAR ═══════════════════════════ -->
    <top>
        <HBox styleClass="top-navbar-conduc" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🚘" styleClass="logo-icon"/>
                <VBox alignment="CENTER_LEFT" spacing="1">
                    <Label text="RideApp" styleClass="app-title"/>
                    <Label text="Espace Conducteur" styleClass="app-subtitle"/>
                </VBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Quick Actions -->
            <HBox alignment="CENTER_RIGHT" spacing="12">

                <!-- Notification Bell avec badge -->
                <StackPane>
                    <Button fx:id="btnNotifications"
                            text="🔔"
                            styleClass="notif-btn-conduc"
                            onAction="#toggleNotificationPanel"/>
                    <Label fx:id="notifBadge" text="2" styleClass="notif-badge-conduc"
                           StackPane.alignment="TOP_RIGHT"
                           visible="false"/>
                </StackPane>

                <!-- Statut disponibilité -->
                <HBox alignment="CENTER" spacing="6" styleClass="disponibilite-box">
                    <Circle fx:id="circleDisponibilite" radius="6" styleClass="dot-disponible"/>
                    <Label fx:id="lblDisponibilite" text="Disponible" styleClass="lbl-disponibilite"/>
                    <ToggleButton fx:id="toggleDispo"
                                  styleClass="toggle-dispo"
                                  onAction="#toggleDisponibilite"/>
                </HBox>

                <!-- Profil -->
                <HBox alignment="CENTER" spacing="8" styleClass="profil-box">
                    <Circle radius="20" styleClass="avatar-conduc"/>
                    <VBox alignment="CENTER_LEFT" spacing="1">
                        <Label fx:id="lblConducteurNom" text="Conducteur" styleClass="nom-utilisateur"/>
                        <HBox alignment="CENTER_LEFT" spacing="4">
                            <Label text="⭐" styleClass="star-icon"/>
                            <Label fx:id="lblNote" text="4.8" styleClass="note-conduc"/>
                        </HBox>
                    </VBox>
                    <Button text="⏻" styleClass="logout-btn" onAction="#logout">
                        <tooltip><Tooltip text="Déconnexion"/></tooltip>
                    </Button>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <!-- ═══════════════════════════ MAIN CONTENT ═══════════════════════════ -->
    <center>
        <StackPane>

            <!-- Main Notebook -->
            <VBox spacing="0">

                <!-- Bandeau KPIs rapides -->
                <HBox styleClass="kpi-banner-conduc" alignment="CENTER" spacing="0">
                    <padding><Insets top="10" right="24" bottom="10" left="24"/></padding>

                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" styleClass="kpi-item">
                        <Label fx:id="kpiRevenuJour" text="—" styleClass="kpi-value-green"/>
                        <Label text="Aujourd'hui" styleClass="kpi-label"/>
                    </VBox>
                    <Separator orientation="VERTICAL"/>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" styleClass="kpi-item">
                        <Label fx:id="kpiTrajetsJour" text="—" styleClass="kpi-value"/>
                        <Label text="Trajets" styleClass="kpi-label"/>
                    </VBox>
                    <Separator orientation="VERTICAL"/>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" styleClass="kpi-item">
                        <Label fx:id="kpiKmJour" text="—" styleClass="kpi-value"/>
                        <Label text="Km parcourus" styleClass="kpi-label"/>
                    </VBox>
                    <Separator orientation="VERTICAL"/>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS" styleClass="kpi-item">
                        <Label fx:id="kpiReservationsEnAttente" text="—" styleClass="kpi-value-orange"/>
                        <Label text="En attente" styleClass="kpi-label"/>
                    </VBox>
                </HBox>

                <!-- TabPane principal -->
                <TabPane fx:id="mainTabPane"
                         styleClass="main-notebook-conduc"
                         tabClosingPolicy="UNAVAILABLE"
                         VBox.vgrow="ALWAYS">

                    <!-- ── TAB 1 : Revenus & Transactions (première) ── -->
                    <Tab fx:id="tabRevenus" text="💰  Revenus" closable="false">
                        <content>
                            <fx:include fx:id="revenusController"
                                        source="../views/conducteur/RevenusTransactions.fxml"/>
                        </content>
                    </Tab>

                    <!-- ── TAB 2 : Trajets & Réservations ── -->
                    <Tab text="🗺️  Mes Trajets" closable="false">
                        <content>
                            <fx:include source="../views/conducteur/TrajetsReservations.fxml"/>
                        </content>
                    </Tab>

                    <!-- ── TAB 3 : Véhicules ── -->
                    <Tab text="🚙  Mes Véhicules" closable="false">
                        <content>
                            <fx:include source="../views/conducteur/GestionVehicules.fxml"/>
                        </content>
                    </Tab>

                    <!-- ── TAB 4 : Maintenance ── -->
                    <Tab text="🔧  Maintenance" closable="false">
                        <content>
                            <fx:include source="../views/conducteur/Maintenance.fxml"/>
                        </content>
                    </Tab>

                    <!-- ── TAB 5 : Forum ── -->
                    <Tab text="💬  Forum" closable="false">
                        <content>
                            <fx:include source="ListeForum.fxml"/>
                        </content>
                    </Tab>

                    <!-- ── TAB 6 : Réclamations ── -->
                    <Tab text="📋  Réclamations" closable="false">
                        <content>
                            <fx:include source="../views/conducteur/Reclamations.fxml"/>
                        </content>
                    </Tab>

                    <!-- ── TAB 7 : Mon Profil ── -->
                    <Tab text="👤  Mon Profil" closable="false">
                        <content>
                            <fx:include source="../views/conducteur/MonProfil.fxml"/>
                        </content>
                    </Tab>

                </TabPane>
            </VBox>

            <!-- ═══ PANNEAU NOTIFICATIONS (slide-in overlay) ═══ -->
            <!-- Affiché/masqué par le controller via fx:id -->
            <VBox fx:id="notificationPanel"
                  styleClass="notif-panel"
                  maxWidth="340"
                  StackPane.alignment="TOP_RIGHT"
                  visible="false"
                  managed="false">
                <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>

                <HBox styleClass="notif-panel-header" alignment="CENTER_LEFT">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                    <Label text="🔔  Notifications" styleClass="notif-panel-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" styleClass="notif-close-btn" onAction="#closeNotificationPanel"/>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="notif-scroll" VBox.vgrow="ALWAYS">
                    <VBox fx:id="notifListContainer" spacing="0" styleClass="notif-list"/>
                </ScrollPane>

                <HBox styleClass="notif-panel-footer" alignment="CENTER">
                    <padding><Insets top="10" right="0" bottom="10" left="0"/></padding>
                    <Button text="Tout marquer comme lu"
                            styleClass="btn-mark-all-read"
                            onAction="#markAllRead"/>
                </HBox>
            </VBox>

        </StackPane>
    </center>

    <!-- ═══════════════════════════ STATUS BAR ═══════════════════════════ -->
    <bottom>
        <HBox styleClass="status-bar-conduc" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="5" right="16" bottom="5" left="16"/></padding>
            <Circle radius="5" styleClass="status-dot-online"/>
            <Label fx:id="lblStatusConduc" text="Connecté" styleClass="status-text-conduc"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblDateTime" text="" styleClass="status-datetime"/>
        </HBox>
    </bottom>

</BorderPane>
