<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ConducteurHomePageController"
            prefWidth="1100.0"
            prefHeight="700.0">

    <!-- HEADER -->
    <top>
        <AnchorPane prefHeight="60.0"
                    style="-fx-background-color: #2c3e50;">
        </AnchorPane>
    </top>

    <!-- NOTEBOOK -->
    <center>

        <TabPane fx:id="conducteurTabs"
                 tabClosingPolicy="UNAVAILABLE"
                 prefWidth="1100.0"
                 prefHeight="640.0">

            <!-- TRAJETS -->
            <Tab text="🛣 Trajets">
                <content>
                    <AnchorPane fx:id="trajetTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- RESERVATIONS -->
            <Tab text="📅 Réservations">
                <content>
                    <AnchorPane fx:id="reservationTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- VEHICULES -->
            <Tab text="🚗 Véhicules">
                <content>
                    <AnchorPane fx:id="vehiculeTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- MAINTENANCE -->
            <Tab text="🛠 Maintenance">
                <content>
                    <AnchorPane fx:id="maintenanceTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- FORUM -->
            <Tab text="💬 Forum">
                <content>
                    <AnchorPane fx:id="forumTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- REVENUE -->
            <Tab fx:id="revenueTabButton"
                 text="💰 Revenus">
                <content>
                    <AnchorPane fx:id="revenueTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- RECLAMATIONS -->
            <Tab text="⚠ Réclamations">
                <content>
                    <AnchorPane fx:id="reclamationTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- PROFILE -->
            <Tab text="👤 Mon Profil">
                <content>
                    <AnchorPane fx:id="profileTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

        </TabPane>

    </center>

</BorderPane>