<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.scene.control.*?>
        <?import javafx.scene.layout.*?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.MesReponsesController"
      style="-fx-padding: 20px; -fx-background-color: #f9f9f9;">

<Label text="Mes Réclamations et Réponses"
       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

<Label text="Sélectionne une réclamation pour voir la réponse de l'admin"
       style="-fx-font-size: 12px; -fx-text-fill: #777;"/>

<!-- Table des réclamations de l'utilisateur -->
<TableView fx:id="tableReclamations" prefHeight="220">
    <columns>
        <TableColumn fx:id="colId"      text="ID"      prefWidth="50"/>
        <TableColumn fx:id="colObjet"   text="Objet"   prefWidth="150"/>
        <TableColumn fx:id="colType"    text="Type"    prefWidth="100"/>
        <TableColumn fx:id="colUrgence" text="Urgence" prefWidth="80"/>
        <TableColumn fx:id="colEtat"    text="Etat"    prefWidth="110"/>
    </columns>
</TableView>

<Button text="Voir la réponse de l'admin"
        onAction="#voirReponse"
        prefWidth="350"
        style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8px; -fx-cursor: hand;"/>

<Separator/>

<!-- Zone réponse admin -->
<Label text="Réponse de l'admin :"
       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

<TextArea fx:id="txtReponseAdmin"
          prefHeight="120"
          editable="false"
          style="-fx-background-color: #ecf0f1; -fx-font-size: 13px; -fx-padding: 8px;"/>

<Label fx:id="lblInfo" style="-fx-font-size: 13px;"/>

<Separator/>

<!-- Navigation -->
<Button text="Ajouter une Réclamation"
        onAction="#retourAjouter"
        prefWidth="350"
        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8px; -fx-cursor: hand;"/>

</VBox>
