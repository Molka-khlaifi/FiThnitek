<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.scene.control.*?>
        <?import javafx.scene.layout.*?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.ListeReclamationController"
      style="-fx-padding: 20px; -fx-background-color: #f9f9f9;">

<Label text="Liste des Réclamations"
       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

<TableView fx:id="tableReclamations" prefHeight="320">
    <columns>
        <TableColumn fx:id="colId"      text="ID"       prefWidth="50"/>
        <TableColumn fx:id="colObjet"   text="Objet"    prefWidth="150"/>
        <TableColumn fx:id="colType"    text="Type"     prefWidth="100"/>
        <TableColumn fx:id="colUrgence" text="Urgence"  prefWidth="80"/>
        <TableColumn fx:id="colEtat"    text="Etat"     prefWidth="110"/>
    </columns>
</TableView>

<HBox spacing="10">
    <Button text="Modifier Statut"  onAction="#modifierStatut"       style="-fx-padding: 8px 14px;"/>
    <Button text="Supprimer"        onAction="#supprimerReclamation"  style="-fx-padding: 8px 14px; -fx-background-color: #e74c3c; -fx-text-fill: white;"/>
    <Button text="Voir Reponses"    onAction="#voirReponses"          style="-fx-padding: 8px 14px; -fx-background-color: #8e44ad; -fx-text-fill: white;"/>
</HBox>

<Label fx:id="lblInfo" style="-fx-font-size: 13px;"/>

<Separator/>

<HBox spacing="10">
    <!-- Retour ajout -->
    <Button text="Ajouter une Réclamation"
            onAction="#retourAjouter"
            prefWidth="220"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8px; -fx-cursor: hand;"/>

    <!-- ✅ Bouton Statistiques -->
    <Button text="Statistiques"
            onAction="#voirStatistiques"
            prefWidth="150"
            style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 8px; -fx-cursor: hand;"/>
</HBox>

</VBox>


