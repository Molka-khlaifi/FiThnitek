<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="460.0" prefWidth="620.0" style="-fx-background-color: #F5F6FA;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.DetailForumController">

    <!-- TOP -->
    <top>
        <VBox>

            <HBox alignment="CENTER_LEFT" prefHeight="56" style="-fx-background-image: url('/BACKGROUND.png');                          -fx-background-size: cover;                          -fx-background-position: center;                          -fx-border-color: #DDE2F0;                          -fx-border-width: 0 0 1 0;                          -fx-padding: 0 20 0 20;                          -fx-spacing: 10;">

                <Label style="-fx-font-size: 14px; -fx-text-fill: #B0B8D8;" text="— Détail forum" />

                <Region HBox.hgrow="ALWAYS" />

                <!-- RETOUR (CORRIGÉ : correspond au controller) -->
                <Button onAction="#retourListeAction" style="-fx-background-color: transparent;                                -fx-text-fill: #2BBF8A;                                -fx-font-weight: bold;                                -fx-cursor: hand;" text="← Retour" />

            </HBox>

            <!-- MESSAGE SUCCESS -->
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: #E6F9F3;                          -fx-padding: 6 20;                          -fx-spacing: 8;">

                <Label style="-fx-text-fill: #1A7A55;                               -fx-font-size: 14px;                               -fx-font-weight: bold;" text="✓" />

                <Label fx:id="messageLabel" style="-fx-text-fill: #1A7A55;                               -fx-font-size: 13px;                               -fx-font-weight: bold;" text="" />

            </HBox>

        </VBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="10" style="-fx-padding: 16 30 16 30;" VBox.vgrow="ALWAYS">

            <!-- DATE PROPRE -->
            <HBox spacing="5">
                <Label style="-fx-font-weight: bold;                               -fx-text-fill: #2D2D6B;                               -fx-font-size: 12px;" text="Publié le :" />

                <Label fx:id="dateLabel" style="-fx-text-fill: #6B6B6B;                               -fx-font-size: 12px;" text="" />
            </HBox>

            <!-- TITRE -->
            <Label style="-fx-font-weight: bold;                           -fx-text-fill: #2D2D6B;                           -fx-font-size: 12px;" text="Titre" />

            <TextField fx:id="titreTextField" editable="false" style="-fx-background-color: #F0F1FA;                               -fx-border-color: #C8D0E8;                               -fx-border-radius: 6;                               -fx-background-radius: 6;" />

            <!-- CAT + STATUT -->
            <HBox spacing="15">

                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 12px;" text="Catégorie" />
                    <TextField fx:id="categorieTextField" editable="false" style="-fx-background-color: #F0F1FA;                                       -fx-border-color: #C8D0E8;                                       -fx-border-radius: 6;                                       -fx-background-radius: 6;" />
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 12px;" text="Statut" />
                    <TextField fx:id="statutTextField" editable="false" style="-fx-background-color: #F0F1FA;                                       -fx-border-color: #C8D0E8;                                       -fx-border-radius: 6;                                       -fx-background-radius: 6;" />
                </VBox>

            </HBox>

            <!-- CONTENU -->
            <Label style="-fx-font-weight: bold;                           -fx-text-fill: #2D2D6B;                           -fx-font-size: 12px;" text="Contenu" />

            <TextArea fx:id="contenuTextArea" editable="false" prefHeight="120" style="-fx-background-color: #F0F1FA;                              -fx-border-color: #C8D0E8;                              -fx-border-radius: 6;                              -fx-background-radius: 6;                              -fx-padding: 8;" />

        </VBox>
    </center>

</BorderPane>
