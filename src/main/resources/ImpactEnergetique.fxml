<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="580.0" prefWidth="800.0"
            style="-fx-background-image: url('/BACKGROUND.png');
                   -fx-background-size: cover;
                   -fx-background-position: center;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ImpactEnergetiqueController">

    <!-- Main header card -->
    <VBox layoutX="30.0" layoutY="25.0"
          prefWidth="560.0"
          prefHeight="85.0"
          spacing="6.0"
          style="-fx-background-color: rgba(255,255,255,0.92);
                 -fx-background-radius: 20;
                 -fx-border-color: rgba(255,255,255,0.70);
                 -fx-border-radius: 20;
                 -fx-padding: 16 20 16 20;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.13), 18, 0, 0, 6);">

        <Label text="Impact énergétique ⚡"
               style="-fx-font-size: 25px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #1f2d3d;" />

        <Label text="Analyse de la répartition énergétique des véhicules enregistrés"
               style="-fx-font-size: 13px;
                      -fx-text-fill: #6b7280;" />
    </VBox>

    <!-- Chart card -->
    <VBox layoutX="30.0" layoutY="130.0"
          prefWidth="360.0"
          prefHeight="350.0"
          spacing="8.0"
          style="-fx-background-color: rgba(255,255,255,0.95);
                 -fx-background-radius: 22;
                 -fx-border-color: #eef2f7;
                 -fx-border-radius: 22;
                 -fx-padding: 14;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.14), 18, 0, 0, 7);">

        <Label text="Répartition par énergie"
               style="-fx-font-size: 17px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #1f2d3d;" />

        <Label text="Essence, diesel, hybride, électrique, GPL..."
               style="-fx-font-size: 11px;
                      -fx-text-fill: #8a94a6;" />

        <PieChart fx:id="energiePieChart"
                  prefHeight="285.0"
                  prefWidth="330.0"
                  legendVisible="true"
                  labelsVisible="true"
                  title="" />
    </VBox>

    <!-- Summary card -->
    <VBox layoutX="410.0" layoutY="130.0"
          prefWidth="180.0"
          prefHeight="350.0"
          spacing="12.0"
          style="-fx-background-color: rgba(255,255,255,0.95);
                 -fx-background-radius: 22;
                 -fx-border-color: #eef2f7;
                 -fx-border-radius: 22;
                 -fx-padding: 16;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.14), 18, 0, 0, 7);">

        <Label text="Résumé"
               style="-fx-font-size: 18px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #1f2d3d;" />

        <VBox prefWidth="145.0"
              prefHeight="55.0"
              spacing="3.0"
              style="-fx-background-color: linear-gradient(to right, #6762ef, #3498db);
                     -fx-background-radius: 16;
                     -fx-padding: 10 12 10 12;">

            <Label text="Parc total"
                   style="-fx-font-size: 11px;
                          -fx-text-fill: rgba(255,255,255,0.85);" />

            <Label fx:id="totalLabel"
                   text="Total : 0 véhicule(s)"
                   style="-fx-font-size: 13px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;" />
        </VBox>

        <Label text="Détails"
               style="-fx-font-size: 13px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #6b7280;" />

        <VBox fx:id="statsBox"
              spacing="8.0"
              style="-fx-padding: 4 0 0 0;" />

        <Label text="Cette vue permet d'évaluer la tendance énergétique globale du parc véhicules."
               wrapText="true"
               style="-fx-font-size: 11px;
                      -fx-text-fill: #8a94a6;" />
    </VBox>

    <!-- Right notebook menu -->
    <VBox layoutX="610.0" layoutY="25.0"
          prefWidth="160.0"
          prefHeight="455.0"
          spacing="14.0"
          style="-fx-background-color: rgba(255,255,255,0.94);
                 -fx-background-radius: 22;
                 -fx-border-color: #eef2f7;
                 -fx-border-radius: 22;
                 -fx-padding: 16;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.14), 18, 0, 0, 7);">

        <Label text="Carnet"
               style="-fx-font-size: 17px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #1f2d3d;" />

        <Label text="Navigation module"
               style="-fx-font-size: 11px;
                      -fx-text-fill: #8a94a6;" />

        <Button onAction="#monEspaceVehiculeAction"
                prefHeight="38.0"
                prefWidth="128.0"
                style="-fx-background-color: white;
                       -fx-text-fill: #1f2d3d;
                       -fx-font-weight: bold;
                       -fx-background-radius: 12;
                       -fx-border-color: #e5e7eb;
                       -fx-border-radius: 12;
                       -fx-cursor: hand;"
                text="Mon espace" />

        <Button onAction="#impactEnergetiqueAction"
                prefHeight="38.0"
                prefWidth="128.0"
                style="-fx-background-color: linear-gradient(to right, #6762ef, #3498db);
                       -fx-text-fill: white;
                       -fx-font-weight: bold;
                       -fx-background-radius: 12;
                       -fx-cursor: hand;"
                text="Impact énergie" />

        <Button onAction="#maintenanceAction"
                prefHeight="38.0"
                prefWidth="128.0"
                style="-fx-background-color: white;
                       -fx-text-fill: #1f2d3d;
                       -fx-font-weight: bold;
                       -fx-background-radius: 12;
                       -fx-border-color: #e5e7eb;
                       -fx-border-radius: 12;
                       -fx-cursor: hand;"
                text="Maintenance" />

        <VBox prefWidth="128.0"
              prefHeight="120.0"
              spacing="6.0"
              style="-fx-background-color: #f8fafc;
                     -fx-background-radius: 16;
                     -fx-padding: 12;
                     -fx-border-color: #eef2f7;
                     -fx-border-radius: 16;">

            <Label text="Objectif"
                   style="-fx-font-size: 12px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1f2d3d;" />

            <Label text="Comprendre l'impact écologique des véhicules utilisés dans l'application."
                   wrapText="true"
                   style="-fx-font-size: 11px;
                          -fx-text-fill: #6b7280;" />
        </VBox>
    </VBox>

    <Label fx:id="messageLabel"
           layoutX="35.0" layoutY="510.0"
           prefWidth="735.0"
           style="-fx-text-fill: #27ae60;
                  -fx-font-size: 12px;
                  -fx-background-color: rgba(255,255,255,0.82);
                  -fx-background-radius: 12;
                  -fx-padding: 8 12 8 12;"
           text="" />

</AnchorPane>