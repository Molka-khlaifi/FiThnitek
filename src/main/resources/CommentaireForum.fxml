<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="560.0" prefWidth="680.0"
            xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.CommentaireForumController"
            style="-fx-background-color: #f9f9f9;">

    <!-- Bouton retour -->
    <Button layoutX="30.0" layoutY="20.0"
            text="← Retour"
            onAction="#retourListeAction"
            prefHeight="30.0" prefWidth="90.0"
            style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-width: 1; -fx-background-radius: 6; -fx-cursor: hand;"/>

    <!-- Titre du forum (affiché en haut) -->
    <Label fx:id="titreForum"
           layoutX="140.0" layoutY="22.0"
           text="..."
           maxWidth="480.0"
           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label layoutX="30.0" layoutY="58.0"
           text="──────────────────────────────────────────────────────────"
           style="-fx-text-fill: #ddd;"/>

    <!-- Infos du post -->
    <Label layoutX="30.0" layoutY="72.0"
           text="Post :"
           style="-fx-text-fill: #888; -fx-font-size: 12px;"/>
    <Label fx:id="infoForumLabel"
           layoutX="72.0" layoutY="72.0"
           text=""
           style="-fx-text-fill: #555; -fx-font-size: 12px;"/>

    <!-- Nombre commentaires -->
    <Label fx:id="nbCommentairesLabel"
           layoutX="30.0" layoutY="100.0"
           text="Commentaires (0)"
           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <!-- Liste des commentaires -->
    <ListView fx:id="commentairesListView"
              layoutX="30.0" layoutY="128.0"
              prefWidth="620.0" prefHeight="240.0"
              style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd; -fx-border-width: 1;"/>

    <!-- Zone actions commentaire -->
    <Label layoutX="30.0" layoutY="382.0"
           text="────────────────────────────────────────────────────────────"
           style="-fx-text-fill: #ddd;"/>

    <!-- ID commentaire pour actions -->
    <Label layoutX="30.0" layoutY="400.0"
           text="ID commentaire :"
           style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-font-size: 12px;"/>
    <TextField fx:id="idCommentaireTextField"
               layoutX="155.0" layoutY="397.0"
               prefWidth="80.0" prefHeight="30.0"
               promptText="ex: 1"
               style="-fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-width: 1; -fx-background-color: white;"/>

    <Button layoutX="250.0" layoutY="397.0"
            text="Liker"
            onAction="#likerAction"
            prefWidth="80.0" prefHeight="30.0"
            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>

    <Button layoutX="345.0" layoutY="397.0"
            text="Supprimer"
            onAction="#supprimerCommentaireAction"
            prefWidth="100.0" prefHeight="30.0"
            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"/>

    <!-- Zone nouveau commentaire -->
    <Label layoutX="30.0" layoutY="445.0"
           text="Nouveau commentaire"
           style="-fx-font-weight: bold; -fx-text-fill: #555;"/>

    <TextArea fx:id="nouveauCommentaireArea"
              layoutX="30.0" layoutY="465.0"
              prefWidth="490.0" prefHeight="70.0"
              promptText="Écrivez votre commentaire ici..."
              wrapText="true"
              style="-fx-background-radius: 6; -fx-border-color: #ddd; -fx-border-width: 1; -fx-background-color: white;"/>

    <Button layoutX="535.0" layoutY="465.0"
            text="Publier"
            onAction="#publierCommentaireAction"
            prefWidth="115.0" prefHeight="70.0"
            style="-fx-background-color: #1abc9c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>

    <!-- Message statut -->
    <Label fx:id="messageLabel"
           layoutX="30.0" layoutY="545.0"
           text=""
           style="-fx-text-fill: #27ae60; -fx-font-size: 12px;"/>

</AnchorPane>
