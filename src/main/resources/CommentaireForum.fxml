<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane
        prefHeight="650.0" prefWidth="680.0"
        style="-fx-background-color: #F5F6FA;"
        xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="controllers.CommentaireForumController">

    <top>
        <VBox>
            <HBox prefHeight="56" alignment="CENTER_LEFT"
                  style="-fx-background-image: url('/BACKGROUND.png');
           -fx-background-size: cover;
           -fx-background-position: center;
           -fx-border-color: #DDE2F0;
           -fx-border-width: 0 0 1 0;
           -fx-padding: 0 20 0 20;
           -fx-spacing: 10;">
                <Button onAction="#retourListeAction" prefHeight="30" prefWidth="90"
                        style="-fx-background-color: #3D3D8A; -fx-text-fill: #C0C8F0;
                           -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 12px;
                           -fx-border-color: #5B5BAA; -fx-border-width: 1; -fx-border-radius: 6;"
                        text="← Retour" />
                <Label text="Fi" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #9B8FD4;" />
                <Label text="Thnitek" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2BBF8A;" />
                <Label text="— Commentaires" style="-fx-font-size: 14px; -fx-text-fill: #B0B8D8;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="nbCommentairesLabel"
                       style="-fx-text-fill: #8892B8; -fx-font-size: 12px;" text="💬 0 commentaire" />
            </HBox>

            <!-- Titre du post -->
            <VBox spacing="2" style="-fx-background-color: #EEEDF8; -fx-padding: 10 14;">
                <Label fx:id="titreForum"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2D2D6B;"
                       text="..." wrapText="true" />
                <Label fx:id="infoForumLabel"
                       style="-fx-font-size: 11px; -fx-text-fill: #7878AA;" text="" />
            </VBox>
        </VBox>
    </top>

    <center>
        <ListView fx:id="commentairesListView"
                  style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 4;" />
    </center>

    <bottom>
        <VBox style="-fx-padding: 0;">
            <HBox spacing="10" alignment="TOP_LEFT"
                  style="-fx-background-color: white; -fx-border-color: #DDE2F0;
                       -fx-border-width: 1 0 0 0; -fx-padding: 12;">
                <StackPane prefWidth="38" prefHeight="38" minWidth="38" minHeight="38">
                    <Circle radius="19" style="-fx-fill: #EEEDF8;" />
                    <Label text="Moi"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2D2D6B;" />
                </StackPane>
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <TextArea fx:id="nouveauCommentaireArea"
                              prefHeight="65"
                              promptText="Écrire un commentaire..."
                              style="-fx-background-radius: 8; -fx-border-color: #C8D0E8;
                               -fx-border-width: 1; -fx-border-radius: 8;
                               -fx-background-color: #F5F6FA; -fx-font-size: 13px;"
                              wrapText="true" />
                    <HBox alignment="CENTER_RIGHT">
                        <Button onAction="#publierCommentaireAction"
                                prefHeight="32" prefWidth="110"
                                style="-fx-background-color: #2BBF8A; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 6;
                                   -fx-cursor: hand; -fx-font-size: 13px;"
                                text="Publier" />
                    </HBox>
                </VBox>
            </HBox>
            <Label fx:id="messageLabel"
                   style="-fx-text-fill: #2BBF8A; -fx-font-size: 12px; -fx-padding: 4 12;" text="" />
        </VBox>
    </bottom>

</BorderPane>