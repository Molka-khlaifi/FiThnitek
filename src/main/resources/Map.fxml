<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.MapController"
      styleClass="page-container"
      spacing="0"
      minWidth="0" minHeight="0"
      maxWidth="Infinity" maxHeight="Infinity">

    <!-- ── Toolbar ── -->
    <HBox styleClass="map-toolbar"
          spacing="12"
          alignment="CENTER_LEFT"
          minHeight="-Infinity"
          VBox.vgrow="NEVER">
        <padding><Insets top="12" left="16" right="16" bottom="12"/></padding>

        <Label text="Carte" style="-fx-font-size:16; -fx-font-weight:bold;"/>

        <ComboBox fx:id="cbTrajets"
                  styleClass="combo-filter"
                  prefWidth="300"
                  promptText="Selectionner un trajet"/>

        <Button text="Afficher sur la carte"
                styleClass="btn-primary"
                onAction="#handleShowTrajet"/>

        <Button text="Vue d ensemble"
                styleClass="btn-secondary"
                onAction="#handleOverview"/>

        <Region HBox.hgrow="ALWAYS"/>

        <ProgressIndicator fx:id="progressMap"
                           prefWidth="24" prefHeight="24"
                           visible="false"/>
    </HBox>

    <!-- ── Info bar JavaFX (durée + distance affichées ici, PAS dans le HTML) ── -->
    <HBox styleClass="map-info-bar"
          alignment="CENTER_LEFT"
          minHeight="-Infinity"
          VBox.vgrow="NEVER">
        <padding><Insets left="16" top="6" right="16" bottom="6"/></padding>
        <Label fx:id="lblInfo"
               text="Vue d ensemble - Tunisie"
               styleClass="map-info-text"/>
    </HBox>

    <!-- ── WebView : occupe TOUT l'espace restant, AUCUN padding/inset ── -->
    <!--
        IMPORTANT : pas de StackPane wrapper avec padding.
        Le WebView doit remplir exactement le reste de la VBox
        pour que ses dimensions (width/height) correspondent à
        ce que Leaflet doit afficher.
    -->
    <WebView fx:id="webView"
             VBox.vgrow="ALWAYS"
             minWidth="0"   minHeight="0"
             maxWidth="Infinity" maxHeight="Infinity"/>

</VBox>
