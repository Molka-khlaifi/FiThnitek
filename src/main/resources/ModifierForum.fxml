<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="480.0" prefWidth="620.0" style="-fx-background-color: #F5F6FA;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ModifierForumController">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="56" style="-fx-background-image: url('/BACKGROUND.png');            -fx-background-size: cover;            -fx-background-position: center;            -fx-border-color: #DDE2F0;            -fx-border-width: 0 0 1 0;            -fx-padding: 0 20 0 20;            -fx-spacing: 10;">
            <Label style="-fx-font-size: 14px; -fx-text-fill: #B0B8D8;" text="— Modifier le Post" />
        </HBox>
    </top>

    <center>
        <VBox prefHeight="439.0" prefWidth="620.0" spacing="10" style="-fx-padding: 16 30 16 30;">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 12px;" text="ID du post" />
                <TextField fx:id="idTextField" editable="false" prefHeight="30" prefWidth="90" style="-fx-background-color: #EDEDF8; -fx-border-color: #C8D0E8;                            -fx-border-width: 1; -fx-background-radius: 6; -fx-border-radius: 6;" />
            </HBox>

            <Label style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 12px;" text="Titre *" />
            <TextField fx:id="titreTextField" maxWidth="Infinity" prefHeight="36" style="-fx-background-radius: 6; -fx-border-radius: 6;                        -fx-border-color: #C8D0E8; -fx-border-width: 1;                        -fx-background-color: white; -fx-padding: 0 10;" />

            <HBox spacing="15">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 12px;" text="Catégorie *" />
                    <ComboBox fx:id="categorieComboBox" maxWidth="Infinity" prefHeight="36" style="-fx-background-radius: 6;" />
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 12px;" text="Statut" />
                    <ComboBox fx:id="statutComboBox" maxWidth="Infinity" prefHeight="36" style="-fx-background-radius: 6;" />
                </VBox>
            </HBox>

            <Label style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 12px;" text="Contenu *" />
            <TextArea fx:id="contenuTextArea" maxWidth="Infinity" prefHeight="120" style="-fx-background-radius: 6; -fx-border-radius: 6;                        -fx-border-color: #C8D0E8; -fx-border-width: 1;                        -fx-background-color: white;" wrapText="true" VBox.vgrow="ALWAYS" />

            <Label fx:id="erreurLabel" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" text="" />

            <HBox spacing="12">
                <Button maxWidth="Infinity" onAction="#modifierForumAction" prefHeight="38" style="-fx-background-color: #2BBF8A; -fx-text-fill: white;                            -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="✓  Enregistrer" HBox.hgrow="ALWAYS" />
                <Button maxWidth="Infinity" onAction="#annulerAction" prefHeight="38" style="-fx-background-color: white; -fx-border-color: #C8D0E8;                            -fx-border-width: 1; -fx-background-radius: 8; -fx-cursor: hand;                            -fx-text-fill: #2D2D6B;" text="Annuler" HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </center>

</BorderPane>
