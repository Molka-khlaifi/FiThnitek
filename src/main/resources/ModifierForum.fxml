<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane
        prefHeight="480.0" prefWidth="620.0"
        style="-fx-background-color: #F5F6FA;"
        xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="controllers.ModifierForumController">

    <top>
        <HBox prefHeight="56" alignment="CENTER_LEFT"
              style="-fx-background-image: url('/BACKGROUND.png');
           -fx-background-size: cover;
           -fx-background-position: center;
           -fx-border-color: #DDE2F0;
           -fx-border-width: 0 0 1 0;
           -fx-padding: 0 20 0 20;
           -fx-spacing: 10;">
            <Label text="Fi" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #9B8FD4;" />
            <Label text="Thnitek" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2BBF8A;" />
            <Label text="— Modifier le Post" style="-fx-font-size: 14px; -fx-text-fill: #B0B8D8;" />
        </HBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-padding: 16 30 16 30;">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="ID du post"
                       style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 12px;" />
                <TextField fx:id="idTextField" editable="false"
                           prefHeight="30" prefWidth="90"
                           style="-fx-background-color: #EDEDF8; -fx-border-color: #C8D0E8;
                           -fx-border-width: 1; -fx-background-radius: 6; -fx-border-radius: 6;" />
            </HBox>

            <Label text="Titre *"
                   style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 12px;" />
            <TextField fx:id="titreTextField"
                       prefHeight="36" maxWidth="Infinity"
                       style="-fx-background-radius: 6; -fx-border-radius: 6;
                       -fx-border-color: #C8D0E8; -fx-border-width: 1;
                       -fx-background-color: white; -fx-padding: 0 10;" />

            <HBox spacing="15">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Catégorie *"
                           style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 12px;" />
                    <ComboBox fx:id="categorieComboBox"
                              prefHeight="36" maxWidth="Infinity"
                              style="-fx-background-radius: 6;" />
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Statut"
                           style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 12px;" />
                    <ComboBox fx:id="statutComboBox"
                              prefHeight="36" maxWidth="Infinity"
                              style="-fx-background-radius: 6;" />
                </VBox>
            </HBox>

            <Label text="Contenu *"
                   style="-fx-font-weight: bold; -fx-text-fill: #2D2D6B; -fx-font-size: 12px;" />
            <TextArea fx:id="contenuTextArea"
                      prefHeight="120" maxWidth="Infinity" VBox.vgrow="ALWAYS"
                      style="-fx-background-radius: 6; -fx-border-radius: 6;
                       -fx-border-color: #C8D0E8; -fx-border-width: 1;
                       -fx-background-color: white;"
                      wrapText="true" />

            <Label fx:id="erreurLabel"
                   style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" text="" />

            <HBox spacing="12">
                <Button onAction="#modifierForumAction" prefHeight="38"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        style="-fx-background-color: #2BBF8A; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                        text="✓  Enregistrer" />
                <Button onAction="#annulerAction" prefHeight="38"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        style="-fx-background-color: white; -fx-border-color: #C8D0E8;
                           -fx-border-width: 1; -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-text-fill: #2D2D6B;" text="Annuler" />
            </HBox>
        </VBox>
    </center>

</BorderPane>