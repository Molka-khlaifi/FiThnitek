<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="480.0" prefWidth="620.0" style="-fx-background-image: url('/BACKGROUND.png');                    -fx-background-size: cover;                    -fx-background-position: center;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ModifierForumController">

    <Label layoutX="30.0" layoutY="25.0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Modifier le Post" />

    <Label layoutX="30.0" layoutY="65.0" style="-fx-text-fill: #cccccc;" text="───────────────────────────────────────────────────" />

    <!-- ID (lecture seule) -->
    <Label layoutX="30.0" layoutY="90.0" style="-fx-font-weight: bold; -fx-text-fill: #555;" text="ID du post" />
    <TextField fx:id="idTextField" editable="false" layoutX="30.0" layoutY="108.0" prefHeight="32.0" prefWidth="100.0" style="-fx-background-color: #eee; -fx-border-color: #ddd; -fx-border-width: 1; -fx-background-radius: 6; -fx-border-radius: 6;" />

    <!-- Titre -->
    <Label layoutX="30.0" layoutY="155.0" style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Titre *" />
    <TextField fx:id="titreTextField" layoutX="30.0" layoutY="175.0" prefHeight="36.0" prefWidth="555.0" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #ddd; -fx-border-width: 1; -fx-background-color: white; -fx-padding: 0 10;" />

    <!-- Categorie -->
    <Label layoutX="30.0" layoutY="228.0" style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Catégorie *" />
    <ComboBox fx:id="categorieComboBox" layoutX="30.0" layoutY="248.0" prefHeight="36.0" prefWidth="250.0" style="-fx-background-radius: 6; -fx-border-radius: 6;" />

    <!-- Statut -->
    <Label layoutX="320.0" layoutY="228.0" style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Statut" />
    <ComboBox fx:id="statutComboBox" layoutX="320.0" layoutY="248.0" prefHeight="36.0" prefWidth="265.0" style="-fx-background-radius: 6; -fx-border-radius: 6;" />

    <!-- Contenu -->
    <Label layoutX="30.0" layoutY="302.0" style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Contenu *" />
    <TextArea fx:id="contenuTextArea" layoutX="30.0" layoutY="322.0" prefHeight="100.0" prefWidth="555.0" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #ddd; -fx-border-width: 1; -fx-background-color: white;" wrapText="true" />

    <!-- Message erreur -->
    <Label fx:id="erreurLabel" layoutX="30.0" layoutY="428.0" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;" text="" />

    <!-- Boutons -->
    <Button layoutX="30.0" layoutY="438.0" onAction="#modifierForumAction" prefHeight="38.0" prefWidth="220.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="✓  Enregistrer modifications" />

    <Button layoutX="270.0" layoutY="438.0" onAction="#annulerAction" prefHeight="38.0" prefWidth="120.0" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-width: 1; -fx-background-radius: 8; -fx-cursor: hand;" text="Annuler" />

</AnchorPane>
