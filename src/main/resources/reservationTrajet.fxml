<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.ReservationController"
      styleClass="page-container"
      spacing="16">
    <padding>
        <Insets top="24" left="24" right="24" bottom="24"/>
    </padding>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch"
                   promptText="Rechercher passager, trajet..."
                   styleClass="search-field"
                   prefWidth="320"/>
        <ComboBox fx:id="cbStatutFilter" styleClass="combo-filter" prefWidth="160"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTotal" styleClass="badge-count"/>
        <Button text="Nouvelle" styleClass="btn-primary"   onAction="#handleNouvelle"/>
        <Button text="Actualiser" styleClass="btn-secondary" onAction="#handleRefresh"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colId"       text="#"          prefWidth="45"/>
            <TableColumn fx:id="colTrajet"   text="Trajet"     prefWidth="160"/>
            <TableColumn fx:id="colPassager" text="Passager"   prefWidth="130"/>
            <TableColumn fx:id="colEmail"    text="Email"      prefWidth="160"/>
            <TableColumn fx:id="colTel"      text="Tel"        prefWidth="100"/>
            <TableColumn fx:id="colPlaces"   text="Places"     prefWidth="65"/>
            <TableColumn fx:id="colDate"     text="Date"       prefWidth="130"/>
            <TableColumn fx:id="colStatut"   text="Statut"     prefWidth="110"/>
            <TableColumn fx:id="colMontant"  text="Montant"    prefWidth="100"/>
            <TableColumn fx:id="colActions"  text="Actions"    prefWidth="280"/>
        </columns>
        <placeholder>
            <Label text="Aucune reservation" styleClass="table-placeholder"/>
        </placeholder>
    </TableView>
</VBox>
