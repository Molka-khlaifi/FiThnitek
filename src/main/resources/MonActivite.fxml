<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="560.0" prefWidth="802.0" style="-fx-background-image: url('/BACKGROUND.png');                    -fx-background-size: cover;                    -fx-background-position: center;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MonActiviteController">

    <!-- HEADER -->
    <Label layoutX="30.0" layoutY="22.0" style="-fx-font-size: 22px;                   -fx-font-weight: bold;                   -fx-text-fill: #085041;" text="📊 Mon Activité" />

    <Label layoutX="30.0" layoutY="55.0" style="-fx-text-fill: #0F6E56;                   -fx-font-size: 12px;" text="Suivez vos statistiques et votre activité sur le forum" />

    <Label layoutX="30.0" layoutY="75.0" style="-fx-text-fill: #9FE1CB;" text="──────────────────────────────────────────────────────────────────" />

    <!-- RETOUR -->
    <Button layoutX="30.0" layoutY="95.0" onAction="#retourMesForumsAction" prefHeight="30.0" prefWidth="160.0" style="-fx-background-color: white;                    -fx-border-color: #0F6E56;                    -fx-border-width: 1;                    -fx-text-fill: #0F6E56;                    -fx-background-radius: 6;                    -fx-font-size: 12px;                    -fx-cursor: hand;" text="← Retour Mes Posts" />

    <!-- SCORE CARD -->
    <AnchorPane layoutX="30.0" layoutY="150.0" prefHeight="120.0" prefWidth="250.0" style="-fx-background-color: white;                        -fx-background-radius: 12;                        -fx-border-radius: 12;                        -fx-border-color: #5DCAA5;                        -fx-border-width: 1.5;">

        <Label layoutX="20.0" layoutY="18.0" style="-fx-font-size: 16px;                       -fx-font-weight: bold;                       -fx-text-fill: #085041;" text="🏆 Score Utilisateur" />

        <Label fx:id="scoreLabel" layoutX="20.0" layoutY="55.0" style="-fx-font-size: 26px;                       -fx-font-weight: bold;                       -fx-text-fill: #1D9E75;" text="0" />

    </AnchorPane>

    <!-- BADGE CARD -->
    <AnchorPane layoutX="320.0" layoutY="150.0" prefHeight="120.0" prefWidth="250.0" style="-fx-background-color: white;                        -fx-background-radius: 12;                        -fx-border-radius: 12;                        -fx-border-color: #5DCAA5;                        -fx-border-width: 1.5;">

        <Label layoutX="20.0" layoutY="18.0" style="-fx-font-size: 16px;                       -fx-font-weight: bold;                       -fx-text-fill: #085041;" text="🎖 Badge Actuel" />

        <Label fx:id="badgeLabel" layoutX="20.0" layoutY="55.0" style="-fx-font-size: 22px;                       -fx-font-weight: bold;                       -fx-text-fill: #f39c12;" text="Débutant" />

    </AnchorPane>

    <!-- GRAPH -->
    <Label layoutX="30.0" layoutY="310.0" style="-fx-font-size: 16px;                   -fx-font-weight: bold;                   -fx-text-fill: #085041;" text="📈 Statistiques du forum" />

    <BarChart fx:id="activityChart" layoutX="30.0" layoutY="340.0" prefHeight="180.0" prefWidth="540.0" style="-fx-background-color: white;                      -fx-background-radius: 12;                      -fx-border-radius: 12;                      -fx-border-color: #5DCAA5;                      -fx-border-width: 1.5;">

        <xAxis>
            <CategoryAxis label="Catégorie" />
        </xAxis>

        <yAxis>
            <NumberAxis label="Nombre" />
        </yAxis>

    </BarChart>

</AnchorPane>
