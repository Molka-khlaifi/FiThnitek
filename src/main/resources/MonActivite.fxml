<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane
        prefHeight="560.0" prefWidth="802.0"
        style="-fx-background-color: #F5F6FA;"
        xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="controllers.MonActiviteController">

    <top>
        <VBox>
            <HBox prefHeight="56" alignment="CENTER_LEFT"
                  style="-fx-background-image: url('/BACKGROUND.png');
           -fx-background-size: cover;
           -fx-background-position: center;
           -fx-border-color: #DDE2F0;
           -fx-border-width: 0 0 1 0;
           -fx-padding: 0 20 0 20;
           -fx-spacing: 10;">
                <Button onAction="#retourMesForumsAction" prefHeight="30" prefWidth="110"
                        style="-fx-background-color: #3D3D8A; -fx-text-fill: #C0C8F0;
                           -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 12px;
                           -fx-border-color: #5B5BAA; -fx-border-width: 1; -fx-border-radius: 6;"
                        text="← Mes Posts" />
                <Label text="Fi" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #9B8FD4;" />
                <Label text="Thnitek" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2BBF8A;" />
                <Label text="— Mon Activité" style="-fx-font-size: 14px; -fx-text-fill: #B0B8D8;" />
            </HBox>
            <Label style="-fx-text-fill: #888; -fx-font-size: 12px; -fx-padding: 6 16;"
                   text="Suivez vos statistiques et votre activité sur le forum" />
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 16;">

            <!-- Cartes stats -->
            <HBox spacing="16">
                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 10;
                           -fx-border-radius: 10; -fx-border-color: #DDE2F0;
                           -fx-border-width: 1; -fx-padding: 16;">
                    <Label text="🏆 Score Utilisateur"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2D2D6B;" />
                    <Label fx:id="scoreLabel" text="0"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2BBF8A;" />
                </VBox>
                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 10;
                           -fx-border-radius: 10; -fx-border-color: #DDE2F0;
                           -fx-border-width: 1; -fx-padding: 16;">
                    <Label text="🎖 Badge Actuel"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2D2D6B;" />
                    <Label fx:id="badgeLabel" text="Débutant"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #F5C842;" />
                </VBox>
            </HBox>

            <!-- Graphique -->
            <Label text="📈 Statistiques du forum"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2D2D6B;" />

            <BarChart fx:id="activityChart"
                      VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 10;
                       -fx-border-radius: 10; -fx-border-color: #DDE2F0; -fx-border-width: 1;">
                <xAxis><CategoryAxis label="Catégorie" /></xAxis>
                <yAxis><NumberAxis label="Nombre" /></yAxis>
            </BarChart>

        </VBox>
    </center>

</BorderPane>