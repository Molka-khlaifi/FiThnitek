<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.revenueController"
            prefHeight="920.0" prefWidth="890.0"
            style="-fx-background-color: white;">

    <!-- Title -->
    <Label layoutX="30.0" layoutY="20.0"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #333;"
           text="💰 Revenues"/>

    <!-- Search -->
    <Label layoutX="30.0" layoutY="60.0"
           style="-fx-font-weight: bold; -fx-text-fill: #555;"
           text="🔍 Search by User ID"/>
    <TextField fx:id="searchField" layoutX="30.0" layoutY="80.0"
               prefHeight="36.0" prefWidth="830.0"
               promptText="Search by User ID..."
               style="-fx-background-radius: 6; -fx-border-radius: 6;
                      -fx-border-color: #ddd; -fx-border-width: 1;
                      -fx-background-color: white; -fx-padding: 0 10;"/>

    <!-- Filters -->
    <Label layoutX="30.0" layoutY="130.0"
           style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Filter by Mois"/>
    <TextField fx:id="filterMoisField" layoutX="30.0" layoutY="150.0"
               prefHeight="36.0" prefWidth="255.0"
               promptText="YYYY-MM"
               style="-fx-background-radius: 6; -fx-border-radius: 6;
                      -fx-border-color: #ddd; -fx-border-width: 1;
                      -fx-background-color: white; -fx-padding: 0 10;"/>

    <Label layoutX="305.0" layoutY="130.0"
           style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Filter by User ID"/>
    <TextField fx:id="filterUserIdField" layoutX="305.0" layoutY="150.0"
               prefHeight="36.0" prefWidth="255.0"
               promptText="User ID"
               style="-fx-background-radius: 6; -fx-border-radius: 6;
                      -fx-border-color: #ddd; -fx-border-width: 1;
                      -fx-background-color: white; -fx-padding: 0 10;"/>

    <Label layoutX="580.0" layoutY="130.0"
           style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Filter by Type"/>
    <ComboBox fx:id="filterTypeField" layoutX="580.0" layoutY="150.0"
              prefHeight="36.0" prefWidth="280.0"
              style="-fx-background-radius: 6; -fx-border-radius: 6;"/>

    <!-- Filter Buttons -->
    <Button layoutX="30.0" layoutY="205.0"
            fx:id="filterBtn" onAction="#applyFilter"
            prefHeight="36.0" prefWidth="140.0"
            style="-fx-background-color: #3498db; -fx-text-fill: white;
                   -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
            text="🔍 Filter"/>

    <Button layoutX="180.0" layoutY="205.0"
            fx:id="resetBtn" onAction="#resetFilter"
            prefHeight="36.0" prefWidth="120.0"
            style="-fx-background-color: white; -fx-border-color: #ddd;
                   -fx-border-width: 1; -fx-background-radius: 8; -fx-cursor: hand;"
            text="↺ Reset"/>

    <Button layoutX="310.0" layoutY="205.0"
            fx:id="deleteBtn" onAction="#deleteRevenue"
            prefHeight="36.0" prefWidth="165.0"
            style="-fx-background-color: white; -fx-border-color: #e74c3c;
                   -fx-border-width: 1; -fx-text-fill: #e74c3c;
                   -fx-background-radius: 8; -fx-cursor: hand;"
            text="🗑 Delete Selected"/>

    <!-- Export Buttons -->
    <Button layoutX="30.0" layoutY="260.0"
            onAction="#exportPDF"
            prefHeight="32.0" prefWidth="145.0"
            style="-fx-background-color: #e74c3c; -fx-text-fill: white;
               -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
            text="📄 Export PDF"/>

    <Button layoutX="185.0" layoutY="260.0"
            onAction="#exportExcel"
            prefHeight="32.0" prefWidth="160.0"
            style="-fx-background-color: #27ae60; -fx-text-fill: white;
               -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
            text="📊 Export Excel"/>

    <!-- Table -->
    <TableView fx:id="revenueTable"
               layoutX="15.0" layoutY="308.0"
               prefHeight="590.0" prefWidth="855.0"
               style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-width: 1;">
        <columns>
            <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
            <TableColumn fx:id="transactionIdCol" text="Trans. ID" prefWidth="85"/>
            <TableColumn fx:id="userIdCol" text="User ID" prefWidth="80"/>
            <TableColumn fx:id="userTypeCol" text="Type" prefWidth="90"/>
            <TableColumn fx:id="montantCol" text="Montant" prefWidth="90"/>
            <TableColumn fx:id="dateCol" text="Date" prefWidth="105"/>
            <TableColumn fx:id="typeRevenueCol" text="Rev. Type" prefWidth="100"/>
            <TableColumn fx:id="moisCol" text="Mois" prefWidth="80"/>
            <TableColumn fx:id="nbPassagersCol" text="Passagers" prefWidth="85"/>
            <TableColumn fx:id="statutCol" text="Statut" prefWidth="90"/>
        </columns>
    </TableView>

</AnchorPane>