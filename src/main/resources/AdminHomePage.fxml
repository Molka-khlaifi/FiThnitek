<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AdminHomeController"
            styleClass="root-pane"
            stylesheets="@../css/admin-theme.css">

    <!-- ═══════════════════════════ TOP NAV BAR ═══════════════════════════ -->
    <top>
        <HBox styleClass="top-navbar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="12" right="24" bottom="12" left="24"/></padding>

            <!-- Logo + App Name -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🚗" styleClass="logo-icon"/>
                <Label text="RideAdmin" styleClass="app-title"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Admin Info + Notifications -->
            <HBox alignment="CENTER_RIGHT" spacing="20">
                <!-- Notification Bell -->
                <StackPane>
                    <Button fx:id="btnNotifications" text="🔔" styleClass="notif-btn"
                            onAction="#openNotifications"/>
                    <Label fx:id="notifBadge" text="3" styleClass="notif-badge"
                           StackPane.alignment="TOP_RIGHT"/>
                </StackPane>

                <!-- Admin Avatar + Name -->
                <HBox alignment="CENTER" spacing="10" styleClass="admin-profile">
                    <Circle fx:id="avatarCircle" radius="18" styleClass="avatar-circle"/>
                    <VBox alignment="CENTER_LEFT" spacing="2">
                        <Label fx:id="lblAdminName" text="Admin" styleClass="admin-name"/>
                        <Label text="Administrateur" styleClass="admin-role-tag"/>
                    </VBox>
                    <Button text="⏻" styleClass="logout-btn" onAction="#logout"
                            tooltip:tooltipText="Déconnexion">
                        <tooltip><Tooltip text="Déconnexion"/></tooltip>
                    </Button>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <!-- ═══════════════════════════ MAIN CONTENT ═══════════════════════════ -->
    <center>
        <VBox spacing="0">

            <!-- Stats Bar -->
            <HBox styleClass="stats-bar" alignment="CENTER" spacing="0">
                <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>

                <VBox alignment="CENTER" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblTotalUsers" text="—" styleClass="stat-number"/>
                    <Label text="Utilisateurs" styleClass="stat-label"/>
                </VBox>
                <Separator orientation="VERTICAL" styleClass="stat-sep"/>
                <VBox alignment="CENTER" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblTotalVehicules" text="—" styleClass="stat-number"/>
                    <Label text="Véhicules" styleClass="stat-label"/>
                </VBox>
                <Separator orientation="VERTICAL" styleClass="stat-sep"/>
                <VBox alignment="CENTER" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblTotalTrajets" text="—" styleClass="stat-number"/>
                    <Label text="Trajets" styleClass="stat-label"/>
                </VBox>
                <Separator orientation="VERTICAL" styleClass="stat-sep"/>
                <VBox alignment="CENTER" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblReclamationsEnAttente" text="—" styleClass="stat-number stat-alert"/>
                    <Label text="Réclamations" styleClass="stat-label"/>
                </VBox>
                <Separator orientation="VERTICAL" styleClass="stat-sep"/>
                <VBox alignment="CENTER" styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblRevenuTotal" text="—" styleClass="stat-number stat-green"/>
                    <Label text="Revenu Total" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <!-- TabPane / Notebook -->
            <TabPane fx:id="mainTabPane" styleClass="main-notebook" tabClosingPolicy="UNAVAILABLE"
                     VBox.vgrow="ALWAYS">

                <!-- ── TAB 1 : Réclamations (première chargée) ── -->
                <Tab fx:id="tabReclamations" text="📋  Réclamations" closable="false">
                    <content>
                        <fx:include fx:id="reclamationsController"
                                    source="../views/admin/GestionReclamations.fxml"/>
                    </content>
                </Tab>

                <!-- ── TAB 2 : Gestion Utilisateurs ── -->
                <Tab text="👥  Utilisateurs" closable="false">
                    <content>
                        <fx:include source="../views/admin/GestionUsers.fxml"/>
                    </content>
                </Tab>

                <!-- ── TAB 3 : Gestion Véhicules ── -->
                <Tab text="🚙  Véhicules" closable="false">
                    <content>
                        <fx:include source="../views/admin/GestionVehicules.fxml"/>
                    </content>
                </Tab>

                <!-- ── TAB 4 : Gestion Maintenance ── -->
                <Tab text="🔧  Maintenance" closable="false">
                    <content>
                        <fx:include source="../views/admin/GestionMaintenance.fxml"/>
                    </content>
                </Tab>

                <!-- ── TAB 5 : Trajets & Réservations ── -->
                <Tab text="🗺️  Trajets" closable="false">
                    <content>
                        <fx:include source="../views/admin/GestionTrajets.fxml"/>
                    </content>
                </Tab>

                <!-- ── TAB 6 : Revenus & Transactions ── -->
                <Tab text="💰  Revenus" closable="false">
                    <content>
                        <fx:include source="../views/admin/GestionRevenus.fxml"/>
                    </content>
                </Tab>

                <!-- ── TAB 7 : Forum ── -->
                <Tab text="💬  Forum" closable="false">
                    <content>
                        <fx:include source="ListeForumAdmin.fxml"/>
                    </content>
                </Tab>

            </TabPane>
        </VBox>
    </center>

    <!-- ═══════════════════════════ STATUS BAR ═══════════════════════════ -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="6" right="16" bottom="6" left="16"/></padding>
            <Circle radius="5" styleClass="status-dot-online"/>
            <Label fx:id="lblStatus" text="Système opérationnel" styleClass="status-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblDateTime" text="" styleClass="status-datetime"/>
        </HBox>
    </bottom>

    <!-- ═══════════════════════════ NOTIFICATION POPUP (overlay) ══════════ -->
    <!-- Géré programmatiquement depuis AdminHomeController -->

</BorderPane>
