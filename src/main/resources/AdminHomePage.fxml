<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.AdminDashboardController"
            prefWidth="1100.0" prefHeight="700.0">

    <!-- HEADER (optionnel simple) -->
    <top>
        <AnchorPane prefHeight="60.0"
                    style="-fx-background-color: #2c3e50;">
        </AnchorPane>
    </top>

    <!-- NOTEBOOK AREA -->
    <center>

        <TabPane fx:id="adminTabs"
                 tabClosingPolicy="UNAVAILABLE"
                 prefWidth="1100.0"
                 prefHeight="640.0">

            <!-- USERS -->
            <Tab text="👤 Utilisateurs">
                <content>
                    <AnchorPane fx:id="usersTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- VEHICLES -->
            <Tab text="🚗 Véhicules">
                <content>
                    <AnchorPane fx:id="vehiclesTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- MAINTENANCE -->
            <Tab text="🛠 Maintenance">
                <content>
                    <AnchorPane fx:id="maintenanceTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- TRIPS / RESERVATIONS -->
            <Tab text="🛣 Trajets & Réservations">
                <content>
                    <AnchorPane fx:id="tripsTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- FORUM (MODERATION IA) -->
            <Tab text="💬 Forum">
                <content>
                    <AnchorPane fx:id="forumTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- RECLAMATIONS -->
            <Tab text="⚠ Réclamations">
                <content>
                    <AnchorPane fx:id="claimsTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- REVENUE -->
            <Tab text="💰 Revenus">
                <content>
                    <AnchorPane fx:id="revenueTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

            <!-- STATISTICS -->
            <Tab text="📊 Statistiques">
                <content>
                    <AnchorPane fx:id="statsTab"
                                prefWidth="1100.0"
                                prefHeight="640.0"/>
                </content>
            </Tab>

        </TabPane>

    </center>

</BorderPane>