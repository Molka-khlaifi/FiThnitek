<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="560.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.MesForumsController"
            style="-fx-background-color: #f0faf5;">

    <!-- Header zone privée -->
    <Label layoutX="30.0" layoutY="25.0"
           text="Mes Posts"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #085041;"/>

    <Label layoutX="30.0" layoutY="55.0"
           text="Seulement vos posts — vous pouvez les modifier et supprimer"
           style="-fx-text-fill: #0F6E56; -fx-font-size: 12px;"/>

    <Label fx:id="statsLabel"
           layoutX="560.0" layoutY="30.0"
           text="0 posts"
           style="-fx-text-fill: #0F6E56; -fx-font-size: 12px;"/>

    <Label layoutX="30.0" layoutY="75.0"
           text="──────────────────────────────────────────────────────────"
           style="-fx-text-fill: #9FE1CB;"/>

    <!-- Bouton retour liste publique -->
    <Button layoutX="30.0" layoutY="90.0"
            text="← Forum public"
            onAction="#retourListeAction"
            prefWidth="140.0" prefHeight="30.0"
            style="-fx-background-color: white; -fx-border-color: #0F6E56; -fx-border-width: 1; -fx-text-fill: #0F6E56; -fx-background-radius: 6; -fx-cursor: hand;"/>

    <!-- Liste de MES posts -->
    <ListView fx:id="mesForumsListView"
              layoutX="30.0" layoutY="132.0"
              prefWidth="640.0" prefHeight="250.0"
              style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #5DCAA5; -fx-border-width: 1;"/>

    <!-- Zone actions -->
    <Label layoutX="30.0" layoutY="395.0"
           text="────────────────────────────────────────────────────────────"
           style="-fx-text-fill: #9FE1CB;"/>

    <Label layoutX="30.0" layoutY="412.0"
           text="ID du post :"
           style="-fx-font-weight: bold; -fx-text-fill: #085041; -fx-font-size: 12px;"/>

    <TextField fx:id="idTextField"
               layoutX="120.0" layoutY="409.0"
               prefWidth="80.0" prefHeight="30.0"
               promptText="ex: 1"
               style="-fx-background-radius: 5; -fx-border-color: #5DCAA5; -fx-border-width: 1; -fx-background-color: white;"/>

    <!-- Boutons actions MES posts -->
    <Button layoutX="30.0" layoutY="458.0"
            text="+ Ajouter"
            onAction="#ajouterAction"
            prefWidth="110.0" prefHeight="36.0"
            style="-fx-background-color: #1D9E75; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;"/>

    <Button layoutX="155.0" layoutY="458.0"
            text="Modifier"
            onAction="#modifierAction"
            prefWidth="100.0" prefHeight="36.0"
            style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;"/>

    <Button layoutX="270.0" layoutY="458.0"
            text="Supprimer"
            onAction="#supprimerAction"
            prefWidth="110.0" prefHeight="36.0"
            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;"/>

    <Button layoutX="395.0" layoutY="458.0"
            text="Epingler"
            onAction="#epinglerAction"
            prefWidth="100.0" prefHeight="36.0"
            style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;"/>

    <Button layoutX="510.0" layoutY="458.0"
            text="Commentaires"
            onAction="#voirCommentairesAction"
            prefWidth="130.0" prefHeight="36.0"
            style="-fx-background-color: #1abc9c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;"/>

    <!-- Message statut -->
    <Label fx:id="messageLabel"
           layoutX="30.0" layoutY="510.0"
           text=""
           style="-fx-text-fill: #0F6E56; -fx-font-size: 12px;"/>

</AnchorPane>
