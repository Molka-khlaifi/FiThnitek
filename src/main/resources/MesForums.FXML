<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="580.0" prefWidth="682.0" style="-fx-background-color: #F5F6FA;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MesForumsController">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" prefHeight="56" style="-fx-background-color:;            -fx-background-size: cover;            -fx-background-position: center;            -fx-border-color: #DDE2F0;            -fx-border-width: 0 0 1 0;            -fx-padding: 0 20 0 20;            -fx-spacing: 10;">
                <Button onAction="#retourListeAction" prefHeight="30" prefWidth="100" style="-fx-background-color: #3D3D8A; -fx-text-fill: #C0C8F0;                            -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 12px;                            -fx-border-color: #5B5BAA; -fx-border-width: 1; -fx-border-radius: 6;" text="← Forum" />
                <Label style="-fx-font-size: 14px; -fx-text-fill: #B0B8D8;" text="— Mes Posts" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="statsLabel" style="-fx-text-fill: #8892B8; -fx-font-size: 12px;" text="0 posts" />
                <Button onAction="#openActiviteAction" prefHeight="32" prefWidth="120" style="-fx-background-color: #9B8FD4; -fx-text-fill: white;                            -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="📊 Mon activité" />
                <Button onAction="#ajouterAction" prefHeight="32" prefWidth="110" style="-fx-background-color: #2BBF8A; -fx-text-fill: white;                            -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="＋ Ajouter" />
            </HBox>
            <Label style="-fx-text-fill: #888; -fx-font-size: 12px; -fx-padding: 6 16;" text="Cliquez sur un post pour le modifier, supprimer ou épingler" />
        </VBox>
    </top>

    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent; -fx-border-width: 0;">
            <content>
                <VBox fx:id="feedContainer" spacing="12" style="-fx-padding: 10 16 10 16;" />
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <Label fx:id="messageLabel" style="-fx-text-fill: #2BBF8A; -fx-font-size: 12px;                    -fx-font-style: italic; -fx-padding: 6 16;" text="" />
    </bottom>

</BorderPane>
