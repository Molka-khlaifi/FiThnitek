<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="580.0" prefWidth="682.0" style="-fx-background-image: url('/BACKGROUND.png');             -fx-background-size: cover;             -fx-background-position: center;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MesForumsController">

    <!-- HEADER -->
    <Label layoutX="30.0" layoutY="22.0" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #085041;" text="📋  Mes Posts" />

    <Label fx:id="statsLabel" layoutX="500.0" layoutY="28.0" style="-fx-text-fill: #1D9E75; -fx-font-size: 12px; -fx-font-weight: bold;" text="0 posts" />

    <Label layoutX="30.0" layoutY="52.0" style="-fx-text-fill: #0F6E56; -fx-font-size: 12px;" text="Seulement vos posts — vous pouvez les modifier et supprimer" />

    <Label layoutX="30.0" layoutY="72.0" style="-fx-text-fill: #9FE1CB;" text="──────────────────────────────────────────────────────────────────" />

    <!-- RETOUR -->
    <Button layoutX="30.0" layoutY="90.0" onAction="#retourListeAction" prefHeight="30.0" prefWidth="140.0" style="-fx-background-color: white;             -fx-border-color: #0F6E56;             -fx-border-width: 1;             -fx-text-fill: #0F6E56;             -fx-background-radius: 6;             -fx-font-size: 12px;             -fx-cursor: hand;" text="← Forum public" />

    <!-- LISTE POSTS -->
    <ScrollPane fitToWidth="true" layoutX="30.0" layoutY="129.0" prefHeight="333.0" prefWidth="648.0" style="-fx-background-color: transparent;">

        <content>

            <VBox fx:id="feedContainer" spacing="15" style="-fx-padding: 10;" />

        </content>

    </ScrollPane>
    <!-- SÉPARATEUR -->
    <Label layoutX="15.0" layoutY="458.0" style="-fx-text-fill: #9FE1CB;" text="──────────────────────────────────────────────────────────────────" />

    <!-- ID -->
    <Label layoutX="30.0" layoutY="476.0" style="-fx-font-weight: bold;            -fx-text-fill: #085041;            -fx-font-size: 12px;" text="ID du post :" />

    <TextField fx:id="idTextField" layoutX="30.0" layoutY="509.0" prefHeight="28.0" prefWidth="80.0" promptText="ex: 1" style="-fx-background-radius: 5;                -fx-border-color: #5dbdca;                -fx-border-width: 1;                -fx-background-color: white;                -fx-font-size: 12px;" />

    <!-- BOUTONS -->
    <Button layoutX="168.0" layoutY="505.0" onAction="#ajouterAction" prefHeight="36.0" prefWidth="115.0" style="-fx-background-color: #1D9E75;             -fx-text-fill: white;             -fx-font-weight: bold;             -fx-background-radius: 7;             -fx-font-size: 12px;             -fx-cursor: hand;" text="＋ Ajouter" />

    <Button layoutX="301.0" layoutY="505.0" onAction="#modifierAction" prefHeight="36.0" prefWidth="105.0" style="-fx-background-color: #f39c12;             -fx-text-fill: white;             -fx-font-weight: bold;             -fx-background-radius: 7;             -fx-font-size: 12px;             -fx-cursor: hand;" text="✏ Modifier" />

    <Button layoutX="426.0" layoutY="505.0" onAction="#supprimerAction" prefHeight="36.0" prefWidth="115.0" style="-fx-background-color: #e74c3c;             -fx-text-fill: white;             -fx-font-weight: bold;             -fx-background-radius: 7;             -fx-font-size: 12px;             -fx-cursor: hand;" text="🗑 Supprimer" />

    <Button layoutX="560.0" layoutY="505.0" onAction="#epinglerAction" prefHeight="36.0" prefWidth="110.0" style="-fx-background-color: #9b59b6;             -fx-text-fill: white;             -fx-font-weight: bold;             -fx-background-radius: 7;             -fx-font-size: 12px;             -fx-cursor: hand;" text="📌 Épingler" />

    <!-- MESSAGE -->
    <Label fx:id="messageLabel" layoutX="30.0" layoutY="520.0" style="-fx-text-fill: #0F6E56;            -fx-font-size: 12px;            -fx-font-style: italic;" text="" />
    <Button layoutX="519.0" layoutY="90.0" onAction="#openActiviteAction" prefHeight="30.0" prefWidth="160.0" style="-fx-background-color: #085041;                -fx-text-fill: white;                -fx-font-weight: bold;                -fx-background-radius: 6;                -fx-cursor: hand;" text="📊 Mon activité" />

</AnchorPane>
