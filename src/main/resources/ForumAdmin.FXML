<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            prefHeight="580.0"
            prefWidth="780.0"
            style="-fx-background-color: #F5F6FA;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ForumAdminController">

    <!-- ================= TOP ================= -->

    <top>
        <VBox>

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT"
                  prefHeight="66"
                  style="-fx-background-color: #F5F6FA;
                         -fx-border-color: #3D3D8A;
                         -fx-border-width: 0 0 1 0;
                         -fx-padding: 0 20 0 20;
                         -fx-spacing: 10;">

                <Label text="🛡 Administration Forum"
                       style="-fx-font-size: 16px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #2D2D6B;" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="statsLabel"
                       text="0 posts"
                       style="-fx-text-fill: #666;
                              -fx-font-size: 12px;" />

                <Button text="🧠 IA Modération"
                        onAction="#openModerationAI"
                        prefHeight="34"
                        prefWidth="150"
                        style="-fx-background-color: #3D3D8A;
                               -fx-text-fill: white;
                               -fx-background-radius: 6;
                               -fx-font-size: 12px;
                               -fx-cursor: hand;
                               -fx-border-color: #5B5BAA;
                               -fx-border-width: 1;
                               -fx-border-radius: 6;" />

                <Button text="📢 Annonce Admin"
                        onAction="#ajouterAnnonceAction"
                        prefHeight="34"
                        prefWidth="150"
                        style="-fx-background-color: #2BBF8A;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 13px;
                               -fx-background-radius: 6;
                               -fx-cursor: hand;" />

            </HBox>

            <!-- TOOLBAR -->
            <HBox alignment="CENTER_LEFT"
                  prefHeight="62"
                  style="-fx-background-color: #F5F6FA;
                         -fx-border-color: #DDE2F0;
                         -fx-border-width: 0 0 1 0;
                         -fx-padding: 0 20 0 20;
                         -fx-spacing: 10;">

                <!-- SEARCH -->
                <TextField fx:id="searchTextField"
                           promptText="🔍 Rechercher un post..."
                           onAction="#rechercherAction"
                           prefHeight="33"
                           prefWidth="220"
                           style="-fx-background-radius: 6;
                                  -fx-border-radius: 6;
                                  -fx-border-color: #DDE2F0;
                                  -fx-border-width: 1;
                                  -fx-background-color: white;
                                  -fx-font-size: 13px;
                                  -fx-padding: 0 10;" />

                <!-- FILTER -->
                <ComboBox fx:id="categorieFilterComboBox"
                          onAction="#filtrerCategorieAction"
                          prefHeight="33"
                          prefWidth="140"
                          style="-fx-background-radius: 6;
                                 -fx-background-color: white;
                                 -fx-border-color: #DDE2F0;
                                 -fx-border-radius: 6;
                                 -fx-font-size: 13px;" />

                <!-- ========== BOUTONS DE MODÉRATION (AJOUTÉS) ========== -->
                <Button text="🚫 Posts masqués"
                        onAction="#voirPostsMasques"
                        prefHeight="32"
                        prefWidth="120"
                        style="-fx-background-color: #3D3D8A;
                               -fx-text-fill: white;
                               -fx-background-radius: 5;
                               -fx-cursor: hand;
                               -fx-font-size: 12px;" />

                <Button text="📌 Posts épinglés"
                        onAction="#voirPostsEpingles"
                        prefHeight="32"
                        prefWidth="120"
                        style="-fx-background-color: #3D3D8A;
                               -fx-text-fill: white;
                               -fx-background-radius: 5;
                               -fx-cursor: hand;
                               -fx-font-size: 12px;" />

                <Button text="🗑 Corbeille"
                        onAction="#voirCorbeille"
                        prefHeight="32"
                        prefWidth="100"
                        style="-fx-background-color: #3D3D8A;
                               -fx-text-fill: white;
                               -fx-background-radius: 5;
                               -fx-cursor: hand;
                               -fx-font-size: 12px;" />

                <Region HBox.hgrow="ALWAYS" />

                <!-- SORT -->
                <Label style="-fx-text-fill: #444;
                              -fx-font-size: 12px;" text="Trier par :" />

                <Button onAction="#trierParDateAction"
                        prefHeight="32"
                        prefWidth="95"
                        style="-fx-background-color: #EEEDF8;
                               -fx-text-fill: #2D2D6B;
                               -fx-background-radius: 5;
                               -fx-font-size: 12px;
                               -fx-cursor: hand;" text="🕐 Récents" />

                <Button onAction="#trierParVuesAction"
                        prefHeight="32"
                        prefWidth="95"
                        style="-fx-background-color: #EEEDF8;
                               -fx-text-fill: #2D2D6B;
                               -fx-background-radius: 5;
                               -fx-font-size: 12px;
                               -fx-cursor: hand;" text="👁 Plus vus" />

            </HBox>

        </VBox>
    </top>

    <!-- ================= CENTER ================= -->

    <center>

        <HBox>

            <!-- POSTS FEED -->
            <ScrollPane fitToWidth="true"
                        fitToHeight="true"
                        pannable="true"
                        style="-fx-background-color: transparent;
                               -fx-border-color: #DDE2F0;
                               -fx-border-width: 0 0 1 0;"
                        HBox.hgrow="ALWAYS">

                <content>
                    <VBox fx:id="feedContainer"
                          spacing="14"
                          style="-fx-padding: 18;" />
                </content>

            </ScrollPane>

            <!-- RIGHT SIDEBAR -->
            <VBox prefWidth="220"
                  spacing="14"
                  style="-fx-background-color: #FAFBFF;
                         -fx-border-color: #DDE2F0;
                         -fx-border-width: 0 0 0 1;
                         -fx-padding: 16 14 16 14;">

                <!-- DASHBOARD ADMIN -->
                <VBox spacing="8"
                      style="-fx-background-color: #EEEDF8;
                             -fx-background-radius: 8;
                             -fx-padding: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">

                    <Label style="-fx-font-weight: bold;
                                  -fx-font-size: 13px;
                                  -fx-text-fill: #2D2D6B;" text="📊 Dashboard Admin" />

                    <Label fx:id="usersCountLabel"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #555;" text="👥 0 utilisateurs" />

                    <Label fx:id="postsCountLabel"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #555;" text="📝 0 posts" />

                    <Label fx:id="commentsCountLabel"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #555;" text="💬 0 commentaires" />

                </VBox>

                <!-- MODERATION -->
                <VBox spacing="8"
                      style="-fx-background-color: #E6F9F3;
                             -fx-background-radius: 8;
                             -fx-padding: 12;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">

                    <Label style="-fx-font-weight: bold;
                                  -fx-font-size: 13px;
                                  -fx-text-fill: #1A7A55;" text="🛡 Modération" />

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-size: 11px;" text="🚫" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #444;" text="Contenus masqués" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-size: 11px;" text="📌" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #444;" text="Posts épinglés" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-size: 11px;" text="🧠" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #444;" text="IA active" />
                    </HBox>

                </VBox>

                <!-- ACTIVITE RECENTE -->
                <VBox spacing="8"
                      style="-fx-background-color: #FFFBEC;
                             -fx-background-radius: 8;
                             -fx-padding: 12;
                             -fx-border-color: #F5C842;
                             -fx-border-width: 1;
                             -fx-border-radius: 8;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">

                    <Label style="-fx-font-weight: bold;
                                  -fx-font-size: 13px;
                                  -fx-text-fill: #7A5800;" text="⚡ Activité récente" />

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-size: 11px;" text="•" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #666;" text="Nouveau post publié" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-size: 11px;" text="•" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #666;" text="Commentaire supprimé" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-size: 11px;" text="•" />
                        <Label style="-fx-font-size: 11px; -fx-text-fill: #666;" text="Utilisateur connecté" />
                    </HBox>

                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <!-- MESSAGE -->
                <Label fx:id="messageLabel"
                       wrapText="true"
                       style="-fx-text-fill: #2BBF8A;
                              -fx-font-size: 11px;" text="" />

            </VBox>

        </HBox>

    </center>

</BorderPane>